<% content_for :title, "Directorate Reports" %>

<div class="px-4 sm:px-6 lg:px-8">
  <div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
      <h1 class="text-base font-semibold leading-6 text-gray-900">Directorate Reports</h1>
      <p class="mt-2 text-sm text-gray-700">All reports submitted to <%= current_user.directorate.name %>.</p>
    </div>
  </div>
  <div class="mt-8 flow-root">
    <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
      <div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">
        <table class="min-w-full divide-y divide-gray-300">
          <thead>
            <tr>
              <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-0">Title</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">State</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Author</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Status</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Submitted</th>
              <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-0">
                <span class="sr-only">View</span>
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @reports.each do |report| %>
              <tr>
                <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900 sm:pl-0">
                  <%= link_to report.title, directorates_report_path(report), class: "hover:text-green-600" %>
                </td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500"><%= report.state.name %></td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500"><%= report.user.first_name %> <%= report.user.last_name %></td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                 <span class="inline-flex items-center rounded-md bg-<%= report.draft? ? 'gray' : (report.approved? ? 'green' : 'yellow') %>-50 px-2 py-1 text-xs font-medium text-<%= report.draft? ? 'gray' : (report.approved? ? 'green' : 'yellow') %>-700 ring-1 ring-inset ring-<%= report.draft? ? 'gray' : (report.approved? ? 'green' : 'yellow') %>-600/20">
                    <%= report.status.humanize %>
                  </span>
                </td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">
                  <%= report.submitted_at&.strftime("%b %d, %Y") || '-' %>
                </td>
                <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-0">
                  <%= link_to "Review", directorates_report_path(report), class: "text-green-600 hover:text-green-900" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
