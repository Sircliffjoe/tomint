<div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
  <%= form_with(model: [:admin, @state, area], class: "space-y-8") do |form| %>
    <% if area.errors.any? %>
      <div class="bg-red-50 p-4 rounded-xl border border-red-100 mb-8">
        <ul class="list-disc pl-5 space-y-1">
          <% area.errors.full_messages.each do |message| %>
            <li class="text-sm text-red-700 font-medium"><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid grid-cols-1 gap-y-12 gap-x-6">
      <div>
        <%= form.label :name, class: "block text-xs font-bold text-gray-400 uppercase tracking-widest ml-1 mb-3" %>
        <%= form.text_field :name, placeholder: "e.g. Asaba Central", class: "block w-full px-4 py-3 bg-gray-50 border border-green-500 rounded-xl text-gray-900 focus:bg-white focus:ring-4 focus:ring-green-600/10 focus:border-green-600 transition-all duration-200 sm:text-sm" %>
      </div>

      <div>
        <%= form.label :description, class: "block text-xs font-bold text-gray-400 uppercase tracking-widest ml-1 mb-3" %>
        <%= form.text_area :description, rows: 4, placeholder: "Operational specifics for this area...", class: "block w-full px-4 py-3 bg-gray-50 border border-green-500 rounded-xl text-gray-900 focus:bg-white focus:ring-4 focus:ring-green-600/10 focus:border-green-600 transition-all duration-200 sm:text-sm" %>
      </div>

      <div>
        <%= form.label :area_leader_id, "Area Leader", class: "block text-xs font-bold text-gray-400 uppercase tracking-widest ml-1 mb-3" %>
        <%= form.select :area_leader_id, @state.users.map { |u| [u.full_name, u.id] }, { include_blank: "— Select Leader (optional) —" }, class: "block w-full px-4 py-3 bg-gray-50 border border-green-500 rounded-xl text-gray-900 focus:bg-white focus:ring-4 focus:ring-green-600/10 focus:border-green-600 transition-all duration-200 sm:text-sm cursor-pointer" %>
      </div>
    </div>

    <div class="flex items-center justify-end pt-8 border-t border-gray-50 gap-4">
      <%= link_to "Cancel", admin_state_areas_path(@state), class: "px-6 py-3 text-sm font-semibold text-gray-500 hover:text-gray-700 transition-colors" %>
      <%= form.submit area.new_record? ? "Create Area" : "Update Area", class: "px-8 py-3 bg-green-600 text-white text-sm font-bold rounded-xl shadow-lg shadow-green-600/20 hover:bg-green-700 hover:shadow-green-600/30 focus:ring-4 focus:ring-green-600/20 active:scale-[0.98] transition-all cursor-pointer" %>
    </div>
  <% end %>
</div>
