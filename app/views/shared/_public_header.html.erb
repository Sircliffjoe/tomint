<header class="absolute inset-x-0 top-0 z-50">
  <nav class="flex items-center justify-between p-6 lg:px-8 bg-leaf-950 shadow-sm" aria-label="Global">
    <div class="flex lg:flex-1">
      <a href="<%= root_path %>" class="-m-1.5 p-1.5">
        <span class="sr-only">TOM Int.</span>
        <!-- Assuming white logo is already suitable for dark bg -->
        <%= image_tag "site-logo-white.png", class: "h-12 w-auto", alt: "TOM Int." %>
      </a>
    </div>
    <div class="flex lg:hidden">
      <!-- Mobile menu trigger -->
      <button type="button" class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-white">
        <span class="sr-only">Open main menu</span>
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
    <div class="hidden lg:flex lg:gap-x-8">
      <%= link_to "Home", root_path, class: "text-sm font-semibold leading-6 text-white hover:text-green-200 transition-colors" %>
      <%= link_to "About", about_path, class: "text-sm font-semibold leading-6 text-white hover:text-green-200 transition-colors" %>
      <%= link_to "Events", events_path, class: "text-sm font-semibold leading-6 text-white hover:text-green-200 transition-colors" %>
      <%= link_to "Training", trainings_path, class: "text-sm font-semibold leading-6 text-white hover:text-green-200 transition-colors" %>
      <%= link_to "Blog", blog_index_path, class: "text-sm font-semibold leading-6 text-white hover:text-green-200 transition-colors" %>
      <%= link_to "Contact", contact_path, class: "text-sm font-semibold leading-6 text-white hover:text-green-200 transition-colors" %>
    </div>
    <div class="hidden lg:flex lg:flex-1 lg:justify-end lg:gap-x-4 items-center">
      <% if user_signed_in? %>
        <%= link_to "Dashboard", dashboard_path, class: "text-sm font-semibold leading-6 text-white hover:text-green-200" %>
        <span class="text-green-400">|</span>
        <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "text-sm font-semibold leading-6 text-white hover:text-green-200 bg-transparent border-0 cursor-pointer" %>
      <% else %>
        <%= link_to "Log in", new_user_session_path, class: "text-sm font-semibold leading-6 text-white hover:text-green-200" %>
        <%= link_to "Donate", new_donation_path, class: "rounded-full bg-white px-4 py-2 text-sm font-semibold text-leaf-900 shadow-sm hover:bg-gray-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white transition-all font-medium" %>
      <% end %>
    </div>
  </nav>
</header>
