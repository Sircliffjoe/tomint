<header class="absolute inset-x-0 top-0 z-50">
  <nav class="flex items-center justify-between p-6 lg:px-8 bg-leaf-950 shadow-sm" aria-label="Global">
    <div class="flex lg:flex-1">
      <a href="<%= root_path %>" class="-m-1.5 p-1.5">
        <%= image_tag "logo-2.png", class: "h-10 w-18" %>
      </a>
    </div>
    <div class="flex lg:hidden">
      <button type="button" id="mobile-menu-open" class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-white">
        <span class="sr-only">Open main menu</span>
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
    <div class="hidden lg:flex lg:gap-x-8">
      <%= link_to "Home", root_path, class: "text-sm font-semibold leading-6 text-white hover:text-green-200 transition-colors" %>
      <%= link_to "About", about_path, class: "text-sm font-semibold leading-6 text-white hover:text-green-200 transition-colors" %>
      <%= link_to "Events", events_path, class: "text-sm font-semibold leading-6 text-white hover:text-green-200 transition-colors" %>
      <%= link_to "Training", trainings_path, class: "text-sm font-semibold leading-6 text-white hover:text-green-200 transition-colors" %>
      <%= link_to "Blog", blog_index_path, class: "text-sm font-semibold leading-6 text-white hover:text-green-200 transition-colors" %>
      <% if Page.exists?(slug: "contact") %>
        <%= link_to "Contact", contact_path, class: "text-sm font-semibold leading-6 text-white hover:text-green-200 transition-colors" %>
      <% end %>
    </div>
    <div class="hidden lg:flex lg:flex-1 lg:justify-end lg:gap-x-4 items-center">
      <% if user_signed_in? %>
        <%= link_to profile_path, class: "flex items-center gap-x-2 text-sm font-semibold leading-6 text-white hover:text-green-200" do %>
          <% if current_user.avatar.attached? %>
            <%= image_tag current_user.avatar, class: "h-8 w-8 rounded-full object-cover ring-2 ring-white/20" %>
          <% else %>
            <div class="h-8 w-8 rounded-full bg-green-500 flex items-center justify-center text-[10px] font-bold text-white">
              <%= current_user.initials %>
            </div>
          <% end %>
          <span>Profile</span>
        <% end %>
        <span class="text-green-800">|</span>
        <%= link_to "Dashboard", dashboard_path, class: "text-sm font-semibold leading-6 text-white hover:text-green-200" %>
        <span class="text-green-800">|</span>
        <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "text-sm font-semibold leading-6 text-white hover:text-green-200 bg-transparent border-0 cursor-pointer" %>
      <% else %>
        <%= link_to "Log in", new_user_session_path, class: "text-sm font-semibold leading-6 text-white hover:text-green-200" %>
        <%= link_to "Donate", new_donation_path, class: "rounded-full bg-white px-4 py-2 text-sm font-semibold text-leaf-900 shadow-sm hover:bg-gray-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white transition-all font-medium" %>
      <% end %>
    </div>
  </nav>

  <!-- Mobile menu panel -->
  <div id="mobile-menu-panel" class="lg:hidden fixed inset-0 z-50" style="display:none;">
    <div id="mobile-menu-backdrop" class="fixed inset-0 bg-black/40"></div>
    <div class="fixed inset-y-0 right-0 w-full max-w-sm bg-leaf-950 px-6 py-6 overflow-y-auto shadow-xl">
      <div class="flex items-center justify-between mb-8">
        <a href="<%= root_path %>" class="-m-1.5 p-1.5">
          <%= image_tag "logo-2.png", class: "h-10 w-18" %>
        </a>
        <button type="button" id="mobile-menu-close" class="-m-2.5 rounded-md p-2.5 text-white">
          <span class="sr-only">Close menu</span>
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div class="space-y-1">
        <%= link_to "Home", root_path, class: "block rounded-lg px-3 py-3 text-base font-semibold text-white hover:bg-white/10" %>
        <%= link_to "About", about_path, class: "block rounded-lg px-3 py-3 text-base font-semibold text-white hover:bg-white/10" %>
        <%= link_to "Events", events_path, class: "block rounded-lg px-3 py-3 text-base font-semibold text-white hover:bg-white/10" %>
        <%= link_to "Training", trainings_path, class: "block rounded-lg px-3 py-3 text-base font-semibold text-white hover:bg-white/10" %>
        <%= link_to "Blog", blog_index_path, class: "block rounded-lg px-3 py-3 text-base font-semibold text-white hover:bg-white/10" %>
        <% if Page.exists?(slug: "contact") %>
          <%= link_to "Contact", contact_path, class: "block rounded-lg px-3 py-3 text-base font-semibold text-white hover:bg-white/10" %>
        <% end %>
      </div>
      <div class="mt-8 pt-6 border-t border-white/20 space-y-3">
        <% if user_signed_in? %>
          <%= link_to "Dashboard", dashboard_path, class: "block rounded-lg px-3 py-3 text-base font-semibold text-white hover:bg-white/10" %>
          <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "w-full text-left rounded-lg px-3 py-3 text-base font-semibold text-white hover:bg-white/10 bg-transparent border-0 cursor-pointer" %>
        <% else %>
          <%= link_to "Log in", new_user_session_path, class: "block rounded-lg px-3 py-3 text-base font-semibold text-white hover:bg-white/10" %>
          <%= link_to "Donate", new_donation_path, class: "block text-center rounded-full bg-white px-4 py-3 text-sm font-semibold text-leaf-900 shadow-sm hover:bg-gray-100 mt-4" %>
        <% end %>
      </div>
    </div>
  </div>
</header>

<script>
  (function() {
    function init() {
      var openBtn = document.getElementById('mobile-menu-open');
      var closeBtn = document.getElementById('mobile-menu-close');
      var panel = document.getElementById('mobile-menu-panel');
      var backdrop = document.getElementById('mobile-menu-backdrop');
      if (!openBtn || !panel) return;
      openBtn.addEventListener('click', function() { panel.style.display = ''; });
      if (closeBtn) closeBtn.addEventListener('click', function() { panel.style.display = 'none'; });
      if (backdrop) backdrop.addEventListener('click', function() { panel.style.display = 'none'; });
    }
    if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', init); } else { init(); }
  })();
</script>
