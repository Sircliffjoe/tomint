<footer class="bg-leaf-950" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Footer</h2>
  <div class="mx-auto max-w-7xl px-6 pb-8 pt-16 sm:pt-24 lg:px-8 lg:pt-32">
    <div class="xl:grid xl:grid-cols-3 xl:gap-8">
      <div class="space-y-8">
        <div class="flex items-center gap-2">
           <%= image_tag "site-logo-white.png", class: "h-14 w-auto", alt: "TOM Int." %>
        </div>
        <p class="text-sm leading-6 text-gray-300">Raising leaders and impacting generations through the gospel of Christ since 1992.</p>
        <div class="flex space-x-6">
          <!-- Social placeholders -->
        </div>
      </div>
      <div class="mt-16 grid grid-cols-2 gap-8 xl:col-span-2 xl:mt-0">
        <div class="md:grid md:grid-cols-2 md:gap-8">
          <div>
            <h3 class="text-sm font-semibold leading-6 text-white">Ministry</h3>
            <ul role="list" class="mt-6 space-y-4">
              <li><a href="<%= events_path %>" class="text-sm leading-6 text-gray-300 hover:text-white hover:text-leaf-300 transition-colors">Events</a></li>
              <li><a href="<%= trainings_path %>" class="text-sm leading-6 text-gray-300 hover:text-white hover:text-leaf-300 transition-colors">Training</a></li>
              <li><a href="<%= blog_index_path %>" class="text-sm leading-6 text-gray-300 hover:text-white hover:text-leaf-300 transition-colors">Blog</a></li>
            </ul>
          </div>
          <div class="mt-10 md:mt-0">
            <h3 class="text-sm font-semibold leading-6 text-white">Organization</h3>
            <ul role="list" class="mt-6 space-y-4">
              <li><a href="<%= about_path %>" class="text-sm leading-6 text-gray-300 hover:text-white hover:text-leaf-300 transition-colors">About Us</a></li>
              <% if Page.exists?(slug: "contact") %>
                <li><a href="<%= contact_path %>" class="text-sm leading-6 text-gray-300 hover:text-white hover:text-leaf-300 transition-colors">Contact</a></li>
              <% end %>
              <li><a href="<%= new_donation_path %>" class="text-sm leading-6 text-gray-300 hover:text-white hover:text-leaf-300 transition-colors">Donate</a></li>
            </ul>
          </div>
        </div>
        <div class="md:grid md:grid-cols-2 md:gap-8">
          <div>
             <h3 class="text-sm font-semibold leading-6 text-white">Legal</h3>
            <ul role="list" class="mt-6 space-y-4">
              <% if Page.exists?(slug: "privacy") %>
                <li><a href="<%= privacy_path %>" class="text-sm leading-6 text-gray-300 hover:text-white hover:text-leaf-300 transition-colors">Privacy Policy</a></li>
              <% end %>
              <% if Page.exists?(slug: "terms") %>
                <li><a href="<%= terms_path %>" class="text-sm leading-6 text-gray-300 hover:text-white hover:text-leaf-300 transition-colors">Terms of Service</a></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
    <div class="mt-16 border-t border-white/10 pt-8 sm:mt-20 lg:mt-24">
      <p class="text-xs leading-5 text-gray-400">&copy; <%= Time.current.year %> Teenagers' Outreach Ministries International. All rights reserved.</p>
    </div>
  </div>
</footer>
