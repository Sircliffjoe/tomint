<div class="space-y-6 border-t border-gray-200 pt-6">
  <h3 class="text-lg font-medium text-gray-900">6. Financial Summary</h3>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    <!-- Income Side -->
    <div>
      <h4 class="text-md font-medium text-gray-800 mb-4 border-b pb-2">Income</h4>
      <div class="space-y-4">
        <% (report.financial_summary&.[]('income') || []).each_with_index do |inc, idx| %>
          <div class="flex items-center space-x-4">
            <div class="flex-1">
              <label class="block text-xs font-medium text-gray-500">Item <%= idx + 1 %></label>
              <input type="text" name="report[financial_summary][income][][item]" value="<%= inc['item'] %>" class="mt-1 block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-green-600 sm:text-sm sm:leading-6" placeholder="Item Name">
            </div>
            <div class="w-32">
              <label class="block text-xs font-medium text-gray-500">Amount (NGN)</label>
              <input type="number" name="report[financial_summary][income][][amount]" value="<%= inc['amount'] %>" class="mt-1 block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-green-600 sm:text-sm sm:leading-6">
            </div>
          </div>
        <% end %>
        <div class="flex items-center space-x-4 pt-4 border-t">
          <div class="flex-1 text-right text-sm font-medium text-gray-900 pr-4">Total Income:</div>
          <div class="w-32">
            <input type="number" name="report[financial_summary][total_income]" value="<%= report.financial_summary&.[]('total_income') %>" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-green-600 sm:text-sm sm:leading-6 font-semibold bg-gray-50">
          </div>
        </div>
      </div>
    </div>

    <!-- Expenses Side -->
    <div>
      <h4 class="text-md font-medium text-gray-800 mb-4 border-b pb-2">Expenses</h4>
      <div class="space-y-4">
        <% (report.financial_summary&.[]('expenses') || []).each_with_index do |exp, idx| %>
          <div class="flex items-center space-x-4">
            <div class="flex-1">
              <label class="block text-xs font-medium text-gray-500">Item <%= idx + 1 %></label>
              <input type="text" name="report[financial_summary][expenses][][item]" value="<%= exp['item'] %>" class="mt-1 block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-green-600 sm:text-sm sm:leading-6" placeholder="Item Name">
            </div>
            <div class="w-32">
              <label class="block text-xs font-medium text-gray-500">Amount (NGN)</label>
              <input type="number" name="report[financial_summary][expenses][][amount]" value="<%= exp['amount'] %>" class="mt-1 block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-green-600 sm:text-sm sm:leading-6">
            </div>
          </div>
        <% end %>
        <div class="flex items-center space-x-4 pt-4 border-t">
          <div class="flex-1 text-right text-sm font-medium text-gray-900 pr-4">Total Expenses:</div>
          <div class="w-32">
            <input type="number" name="report[financial_summary][total_expenses]" value="<%= report.financial_summary&.[]('total_expenses') %>" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-green-600 sm:text-sm sm:leading-6 font-semibold bg-gray-50">
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-6 flex items-center justify-end space-x-4 bg-gray-50 p-4 rounded-lg border">
    <label class="block text-sm font-semibold text-gray-900">Total Deficit (if applicable):</label>
    <div class="w-48">
      <input type="number" name="report[financial_summary][deficit]" value="<%= report.financial_summary&.[]('deficit') %>" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-red-600 sm:text-sm sm:leading-6 text-red-600 font-semibold bg-white">
    </div>
  </div>
</div>
