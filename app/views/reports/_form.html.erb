<%= form_with(model: report, class: "space-y-6") do |form| %>
  <% if report.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-lg mt-3">
      <h2><%= pluralize(report.errors.count, "error") %> prohibited this report from being saved:</h2>

      <ul>
        <% report.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <%= form.text_field :title, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
    </div>
  </div>

  <div>
    <%= form.label :report_category_id, "Category", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <%= form.collection_select :report_category_id, ReportCategory.all, :id, :name, { prompt: "Select a Category" }, { class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" } %>
    </div>
  </div>

  <div>
    <%= form.label :body, class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1 prose max-w-none">
      <%= form.rich_text_area :body, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-green-500 focus:ring-green-500 sm:text-sm min-h-[300px]" %>
    </div>
  </div>

  <div class="space-y-8 mt-12 bg-gray-50 p-6 rounded-lg border border-gray-200 shadow-inner">
    <%= render "clubs_section", form: form, report: report %>
    <%= render "programmes_section", form: form, report: report %>
    <%= render "seminars_section", form: form, report: report %>
    <%= render "meetings_section", form: form, report: report %>
    <%= render "external_engagements_section", form: form, report: report %>
    <%= render "financial_section", form: form, report: report %>
    <%= render "others_section", form: form, report: report %>
  </div>

  <div class="flex justify-end pt-5 border-t border-gray-200">
    <%= link_to "Cancel", reports_path, class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 mr-3" %>
    <%= form.submit "Create Report", class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
  </div>
<% end %>
