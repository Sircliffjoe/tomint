<%= form_with(model: report, class: "space-y-6") do |form| %>
  <% if report.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-lg mt-3">
      <h2><%= pluralize(report.errors.count, "error") %> prohibited this report from being saved:</h2>

      <ul>
        <% report.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <%= form.text_field :title, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
    </div>
  </div>

  <div>
    <%= form.label :report_category_id, "Category", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <%= form.collection_select :report_category_id, ReportCategory.all, :id, :name, { prompt: "Select a Category" }, { class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" } %>
    </div>
  </div>

  <div>
    <%= form.label :body, class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1 prose max-w-none">
      <%= form.rich_text_area :body, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-green-500 focus:ring-green-500 sm:text-sm min-h-[300px]" %>
    </div>
  </div>

  <!-- Dynamic Fields Sections -->
  <div id="camp-fields" class="hidden space-y-6 border-t border-gray-200 pt-6">
    <h3 class="text-lg font-medium text-gray-900">Camp Details</h3>
    <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-2">
      <div>
        <%= form.label :camp_date, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.date_field :camp_date, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
        </div>
      </div>
      <div>
        <%= form.label :location, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.text_field :location, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
        </div>
      </div>
      <div>
        <%= form.label :attendees_count, "Number of Attendees", class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.number_field :attendees_count, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
        </div>
      </div>
      <div>
        <%= form.label :decisions_count, "Number of Decisions", class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.number_field :decisions_count, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
        </div>
      </div>
    </div>
  </div>

  <div id="financial-fields" class="hidden space-y-6 border-t border-gray-200 pt-6">
    <h3 class="text-lg font-medium text-gray-900">Financial Details</h3>
    <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-3">
      <div>
        <%= form.label :total_income, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.number_field :total_income, step: "0.01", class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
        </div>
      </div>
      <div>
        <%= form.label :total_expenses, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.number_field :total_expenses, step: "0.01", class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
        </div>
      </div>
      <div>
        <%= form.label :currency, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.select :currency, ["NGN", "USD", "EUR", "GBP"], {}, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
        </div>
      </div>
    </div>
  </div>

  <div id="training-fields" class="hidden space-y-6 border-t border-gray-200 pt-6">
    <h3 class="text-lg font-medium text-gray-900">Training Details</h3>
    <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-2">
      <div>
        <%= form.label :training_date, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.date_field :training_date, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
        </div>
      </div>
      <div>
        <%= form.label :participants_count, "Number of Participants", class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.number_field :participants_count, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
        </div>
      </div>
      <div class="sm:col-span-2">
        <%= form.label :topic, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.text_field :topic, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
        </div>
      </div>
    </div>
  </div>

  <div id="media-fields" class="hidden space-y-6 border-t border-gray-200 pt-6">
    <h3 class="text-lg font-medium text-gray-900">Media Stats</h3>
    <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-3">
      <div>
        <%= form.label :platform, "Platform (e.g. Facebook, Radio)", class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.text_field :platform, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
        </div>
      </div>
      <div>
        <%= form.label :reach_count, "Reach", class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.number_field :reach_count, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
        </div>
      </div>
      <div>
        <%= form.label :engagement_count, "Engagements", class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.number_field :engagement_count, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
        </div>
      </div>
    </div>
  </div>

  <div id="annual-fields" class="hidden space-y-6 border-t border-gray-200 pt-6">
    <h3 class="text-lg font-medium text-gray-900">Annual Report Details</h3>
    <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-2">
      <div>
        <%= form.label :year, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.number_field :year, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
        </div>
      </div>
      <div>
        <%= form.label :total_events, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.number_field :total_events, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
        </div>
      </div>
      <div class="sm:col-span-2">
        <%= form.label :highlights, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.text_area :highlights, rows: 3, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
        </div>
      </div>
      <div class="sm:col-span-2">
        <%= form.label :challenges, class: "block text-sm font-medium text-gray-700" %>
        <div class="mt-1">
          <%= form.text_area :challenges, rows: 3, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function() {
      function initReportForm() {
        const categorySelect = document.querySelector("select[name='report[report_category_id]']");
        if (!categorySelect) return;

        const sections = {
          "Camp Report": document.getElementById("camp-fields"),
          "Financial Report": document.getElementById("financial-fields"),
          "Training Report": document.getElementById("training-fields"),
          "Media Report": document.getElementById("media-fields"),
          "Annual Report": document.getElementById("annual-fields")
        };

        function toggleSections() {
          const selectedOption = categorySelect.options[categorySelect.selectedIndex];
          const categoryName = selectedOption ? selectedOption.text : "";
          
          Object.keys(sections).forEach(key => {
            const section = sections[key];
            if (section) {
              if (key === categoryName) {
                section.classList.remove("hidden");
              } else {
                section.classList.add("hidden");
              }
            }
          });
        }

        categorySelect.addEventListener("change", toggleSections);
        toggleSections(); // Initial state
      }

      document.addEventListener("turbo:load", initReportForm);
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initReportForm);
      } else {
        initReportForm();
      }
    })();
  </script>

  <div class="flex justify-end pt-5 border-t border-gray-200">
    <%= link_to "Cancel", reports_path, class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 mr-3" %>
    <%= form.submit "Create Report", class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
  </div>
<% end %>
