<div class="space-y-6 border-t border-gray-200 pt-6">
  <h3 class="text-lg font-medium text-gray-900">3. Seminars/Trainings</h3>
  <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
    <div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">
      <table class="min-w-full divide-y divide-gray-300">
        <thead>
          <tr>
            <th class="py-3 pl-4 pr-3 text-left text-sm font-semibold text-gray-900">Seminars/Trainings</th>
            <th class="px-3 py-3 text-left text-sm font-semibold text-gray-900">LGA/Zone/Group</th>
            <th class="px-3 py-3 text-left text-sm font-semibold text-gray-900 w-24">Trainees</th>
            <th class="px-3 py-3 text-left text-sm font-semibold text-gray-900 w-24">Facilitators</th>
            <th class="px-3 py-3 text-left text-sm font-semibold text-gray-900 w-24">Mobilized</th>
            <th class="px-3 py-3 text-left text-sm font-semibold text-gray-900 w-32">Cost</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white">
          <% report.seminars.each do |sem| %>
            <tr>
              <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900">
                <%= sem['type'] %>
                <input type="hidden" name="report[seminars][][type]" value="<%= sem['type'] %>">
              </td>
              <td class="whitespace-nowrap px-3 py-2 text-sm text-gray-500">
                <input type="text" name="report[seminars][][lga]" value="<%= sem['lga'] %>" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-green-600 sm:text-sm sm:leading-6">
              </td>
              <td class="whitespace-nowrap px-3 py-2 text-sm text-gray-500">
                <input type="number" name="report[seminars][][trainees]" value="<%= sem['trainees'] %>" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-green-600 sm:text-sm sm:leading-6">
              </td>
              <td class="whitespace-nowrap px-3 py-2 text-sm text-gray-500">
                <input type="number" name="report[seminars][][facilitators]" value="<%= sem['facilitators'] %>" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-green-600 sm:text-sm sm:leading-6">
              </td>
              <td class="whitespace-nowrap px-3 py-2 text-sm text-gray-500">
                <input type="number" name="report[seminars][][mobilized]" value="<%= sem['mobilized'] %>" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-green-600 sm:text-sm sm:leading-6">
              </td>
              <td class="whitespace-nowrap px-3 py-2 text-sm text-gray-500">
                <input type="number" name="report[seminars][][cost]" value="<%= sem['cost'] %>" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-green-600 sm:text-sm sm:leading-6">
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
