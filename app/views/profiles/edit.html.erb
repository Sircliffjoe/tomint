<div class="max-w-3xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
  <div class="px-4 py-3 sm:px-6">
    <h3 class="text-2xl font-bold leading-6 text-gray-900">Edit Profile</h3>
    <p class="mt-1 max-w-2xl text-sm text-gray-500">Update your personal information and profile picture.</p>
  </div>

  <div class="mt-6 border-t border-gray-100">
    <%= form_with(model: @user, url: profile_path, method: :patch, local: true, class: "space-y-8 divide-y divide-gray-200") do |f| %>
      <% if @user.errors.any? %>
        <div class="rounded-md bg-red-50 p-4 mb-6">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-red-800"><%= pluralize(@user.errors.count, "error") %> prohibited this profile from being saved:</h3>
              <div class="mt-2 text-sm text-red-700">
                <ul class="list-disc space-y-1 pl-5">
                  <% @user.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <div class="pt-8">
        <div class="grid grid-cols-1 gap-y-6 sm:grid-cols-6 sm:gap-x-4">
          <!-- Avatar Upload -->
          <div class="sm:col-span-6">
            <label for="avatar" class="block text-sm font-medium text-gray-700">Profile picture</label>
            <div class="mt-2 flex items-center gap-x-3">
              <% if @user.avatar.attached? %>
                <%= image_tag @user.avatar, class: "h-12 w-12 rounded-full object-cover" %>
              <% else %>
                <div class="h-12 w-12 rounded-full bg-gray-100 flex items-center justify-center">
                  <svg class="h-7 w-7 text-gray-300" viewBox="0 0 24 24" fill="currentColor">
                    <path fill-rule="evenodd" d="M18.685 19.097A9.723 9.723 0 0021.75 12c0-5.385-4.365-9.75-9.75-9.75S2.25 6.615 2.25 12c0 2.671 1.073 5.093 2.815 6.866a.75.75 0 001.196-.06l1.293-2.155a.75.75 0 011.23-.035 7.243 7.243 0 0010.517 0 .75.75 0 011.23.035l1.293 2.155a.75.75 0 001.196.06zM15.75 9a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" clip-rule="evenodd" />
                  </svg>
                </div>
              <% end %>
              <%= f.file_field :avatar, class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
            </div>
          </div>

          <div class="sm:col-span-3">
            <%= f.label :first_name, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= f.text_field :first_name, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            </div>
          </div>

          <div class="sm:col-span-3">
            <%= f.label :last_name, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <%= f.text_field :last_name, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            </div>
          </div>
        </div>
      </div>

      <div class="pt-5 pb-10">
        <div class="flex justify-end gap-x-3">
          <%= link_to "Cancel", profile_path, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
          <%= f.submit "Save Changes", class: "inline-flex justify-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
