<div class="px-4 sm:px-6 lg:px-8">
  <div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
      <h1 class="text-2xl font-semibold text-gray-900">Areas in <%= @state.name %></h1>
      <p class="mt-2 text-sm text-gray-700">Manage areas under this state.</p>
    </div>
    <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none space-x-2">
      <%= link_to "← Back to States", admin_states_path, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" %>
      <%= link_to "Add Area", new_admin_state_area_path(@state), class: "rounded-md bg-green-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-green-500" %>
    </div>
  </div>

  <div class="mt-8 flow-root">
    <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
      <div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">
        <table class="min-w-full divide-y divide-gray-300">
          <thead>
            <tr>
              <th class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900">Name</th>
              <th class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Description</th>
              <th class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Area Leader</th>
              <th class="relative py-3.5 pl-3 pr-4"><span class="sr-only">Actions</span></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% @areas.each do |area| %>
              <tr>
                <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900"><%= area.name %></td>
                <td class="px-3 py-4 text-sm text-gray-500"><%= truncate(area.description, length: 60) %></td>
                <td class="px-3 py-4 text-sm text-gray-500"><%= area.area_leader ? "#{area.area_leader.first_name} #{area.area_leader.last_name}" : "—" %></td>
                <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium space-x-2">
                  <%= link_to "Edit", edit_admin_state_area_path(@state, area), class: "text-green-600 hover:text-green-900" %>
                  <%= button_to "Delete", admin_state_area_path(@state, area), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "text-red-600 hover:text-red-900" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
