<div class="px-4 sm:px-6 lg:px-8 py-8 w-full max-w-9xl mx-auto">

  <!-- Page header -->
  <div class="sm:flex sm:justify-between sm:items-center mb-8">
    <div class="mb-4 sm:mb-0">
      <h1 class="text-2xl md:text-3xl text-gray-800 font-bold tracking-tight">Training: <%= @training.title %></h1>
      <div class="mt-2 text-sm text-gray-500 flex items-center gap-2">
        <%= link_to "Trainings", admin_trainings_path, class: "hover:text-green-600 transition-colors" %>
        <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-gray-900 font-medium truncate"><%= @training.title %></span>
      </div>
    </div>
    
    <div class="grid grid-flow-col sm:auto-cols-max justify-start sm:justify-end gap-3">
      <%= link_to edit_admin_training_path(@training), class: "btn bg-white border-green-200 hover:border-green-300 text-green-600 shadow-sm" do %>
        <svg class="w-4 h-4 fill-current opacity-50 shrink-0 mr-2" viewBox="0 0 16 16">
          <path d="M11.7.3c-.4-.4-1-.4-1.4 0l-10 10c-.2.2-.3.4-.3.7v4c0 .6.4 1 1 1h4c.3 0 .5-.1.7-.3l10-10c.4-.4.4-1 0-1.4l-4-4zM4.6 14H2v-2.6l6-6L10.6 8l-6 6zM12 6.6L9.4 4 11 2.4 13.6 5 12 6.6z" />
        </svg>
        <span class="hidden xs:block ml-2">Edit Training</span>
      <% end %>
      <a href="<%= training_path(@training) %>" target="_blank" class="btn bg-green-600 hover:bg-green-700 text-white shadow-sm">
        <svg class="w-4 h-4 fill-current opacity-50 shrink-0 mr-2" viewBox="0 0 16 16">
          <path d="M15 15H1V1h7V0H0v16h16V8h-1v7z" />
          <path d="M10 0v1h4.3L6.6 8.6l.7.7L15 1.7V6h1V0z" />
        </svg>
        <span class="hidden xs:block ml-2">View Live</span>
      </a>
    </div>
  </div>

  <div class="bg-white shadow-sm rounded-xl border border-gray-200 p-6 mb-8">
    <div class="border-b border-gray-100 pb-4 mb-4">
      <h2 class="text-lg font-semibold text-gray-800">Training Details</h2>
    </div>

    <dl class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-4 gap-y-8 sm:gap-x-8">
      <div class="sm:col-span-1 lg:col-span-2">
        <dt class="text-sm font-medium text-gray-500 uppercase tracking-wide">Title</dt>
        <dd class="mt-1 text-base text-gray-900 font-semibold"><%= @training.title %></dd>
      </div>
      <div class="sm:col-span-1">
        <dt class="text-sm font-medium text-gray-500 uppercase tracking-wide">Category</dt>
        <dd class="mt-1 text-base text-gray-900"><%= @training.category.presence || "General" %></dd>
      </div>
      <div class="sm:col-span-1 border-t border-gray-100 pt-6">
        <dt class="text-sm font-medium text-gray-500 uppercase tracking-wide">State Target</dt>
        <dd class="mt-1 text-base text-gray-900">
          <% if @training.state %>
            <%= link_to @training.state.name, admin_state_path(@training.state), class: "text-green-600 hover:text-green-800 transition-colors" %>
          <% else %>
            <span class="text-gray-400">All States (Global)</span>
          <% end %>
        </dd>
      </div>
      <div class="sm:col-span-2 border-t border-gray-100 pt-6">
        <dt class="text-sm font-medium text-gray-500 uppercase tracking-wide">Description</dt>
        <dd class="mt-1 text-sm text-gray-900 leading-relaxed"><%= @training.description.presence || "No description provided." %></dd>
      </div>
    </dl>
  </div>

  <!-- Training Sessions -->
  <div class="bg-white shadow-sm rounded-xl border border-gray-200 p-6">
    <div class="flex justify-between items-center border-b border-gray-100 pb-4 mb-4">
      <h2 class="text-lg font-semibold text-gray-800">Course Modules/Sessions (<%= @training.training_sessions.count %>)</h2>
      <%= link_to "Add Session", new_admin_training_training_session_path(@training), class: "text-sm font-medium text-green-600 hover:text-green-700 bg-green-50 hover:bg-green-100 px-3 py-1.5 rounded-md transition-colors" %>
    </div>
    
    <% if @training.training_sessions.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Title</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Duration</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Media URL</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @training.training_sessions.order(:id).each do |session| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm font-medium text-gray-900"><%= link_to session.title, admin_training_training_session_path(@training, session), class: "hover:text-green-600" %></div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-gray-500"><%= session.duration %> mins</div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="text-sm text-gray-500 truncate max-w-[200px]" title="<%= session.media_url %>">
                    <% if session.media_url.present? %>
                      <a href="<%= session.media_url %>" target="_blank" class="text-blue-600 hover:underline"><%= session.media_url %></a>
                    <% else %>
                      <span class="text-gray-400">None</span>
                    <% end %>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <%= link_to "Edit", edit_admin_training_training_session_path(@training, session), class: "text-green-600 hover:text-green-900 mr-3" %>
                  <%= link_to "Delete", admin_training_training_session_path(@training, session), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-red-600 hover:text-red-900" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-12 text-gray-400 border border-dashed border-gray-200 rounded-lg">
        <svg class="mx-auto h-12 w-12 text-gray-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
        <p class="text-sm text-gray-500 font-medium mb-1">No sessions added yet</p>
        <p class="text-xs text-gray-400">Click the "Add Session" button above to structure this training.</p>
      </div>
    <% end %>
  </div>

</div>
