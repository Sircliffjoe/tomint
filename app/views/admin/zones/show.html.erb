<div class="show-page">
  <div class="show-header">
    <div>
      <div class="show-breadcrumb">
        <%= link_to "Zones", admin_zones_path, class: "breadcrumb-link" %>
        <svg class="breadcrumb-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="breadcrumb-current"><%= @zone.name %></span>
      </div>
      <h1 class="show-title"><%= @zone.name %></h1>
      <p class="show-subtitle">Zone</p>
    </div>
    <div class="show-actions">
      <%= link_to edit_admin_zone_path(@zone), class: "action-btn action-btn--primary" do %>
        <svg class="action-btn-icon" viewBox="0 0 16 16" fill="currentColor"><path d="M11.7.3c-.4-.4-1-.4-1.4 0l-10 10c-.2.2-.3.4-.3.7v4c0 .6.4 1 1 1h4c.3 0 .5-.1.7-.3l10-10c.4-.4.4-1 0-1.4l-4-4zM4.6 14H2v-2.6l6-6L10.6 8l-6 6zM12 6.6L9.4 4 11 2.4 13.6 5 12 6.6z"/></svg>
        Edit Zone
      <% end %>
    </div>
  </div>

  <div class="show-grid show-grid--sidebar">
    <div class="show-main">
      <div class="show-card">
        <div class="show-card-header"><h2 class="show-card-title">Zone Details</h2></div>
        <div class="detail-list">
          <div class="detail-item">
            <span class="detail-label">Name</span>
            <span class="detail-value detail-value--strong"><%= @zone.name %></span>
          </div>
          <div class="detail-item detail-item--full">
            <span class="detail-label">Description</span>
            <span class="detail-value detail-value--prose"><%= @zone.description.presence || "No description provided." %></span>
          </div>
        </div>
      </div>

      <div class="show-card">
        <div class="show-card-header"><h2 class="show-card-title">Zonal Directors</h2></div>
        <% directors = User.where(role: :zonal_director) %>
        <% if directors.any? %>
          <ul class="people-grid">
            <% directors.each do |director| %>
              <li class="person-card">
                <div class="person-avatar"><%= director.initials %></div>
                <div class="person-info">
                  <p class="person-name"><%= link_to director.full_name, admin_user_path(director), class: "person-link" %></p>
                  <p class="person-email"><%= director.email %></p>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="empty-state">
            <svg class="empty-state-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <p class="empty-state-text">No zonal directors assigned.</p>
          </div>
        <% end %>
      </div>

      <div class="show-card">
        <div class="show-card-header">
          <h2 class="show-card-title">States in Zone</h2>
          <span class="badge badge--gray"><%= @zone.states.count %> States</span>
        </div>
        <% if @zone.states.any? %>
          <ul class="item-grid">
            <% @zone.states.each do |state| %>
              <li class="item-card">
                <div class="item-card-header">
                  <%= link_to state.name, admin_state_path(state), class: "item-card-name" %>
                  <span class="status-dot <%= state.status == 'active' ? 'status-dot--active' : 'status-dot--inactive' %>"></span>
                </div>
                <span class="item-card-meta"><%= state.areas.count %> Areas</span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="empty-state">
            <svg class="empty-state-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
            <p class="empty-state-text">No states assigned to this zone yet.</p>
          </div>
        <% end %>
      </div>
    </div>

    <div class="show-sidebar">
      <div class="show-card">
        <div class="show-card-header"><h2 class="show-card-title">Summary</h2></div>
        <div class="stat-list">
          <div class="stat-item">
            <span class="stat-label">States</span>
            <span class="stat-value"><%= @zone.states.count %></span>
          </div>
          <div class="stat-item">
            <span class="stat-label">Directors</span>
            <span class="stat-value"><%= User.where(role: :zonal_director).count %></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<style>
.show-page{padding:2rem 1.5rem;max-width:1280px;margin:0 auto;font-family:"Georgia",serif}
@media(min-width:640px){.show-page{padding:2rem 2rem}}
.show-header{display:flex;flex-direction:column;gap:1rem;margin-bottom:2rem}
@media(min-width:640px){.show-header{flex-direction:row;align-items:flex-start;justify-content:space-between}}
.show-breadcrumb{display:flex;align-items:center;gap:.375rem;font-size:.8rem;margin-bottom:.5rem;flex-wrap:wrap}
.breadcrumb-link{color:#6b7280;text-decoration:none;transition:color .15s}
.breadcrumb-link:hover{color:#16a34a}
.breadcrumb-chevron{width:14px;height:14px;color:#d1d5db;flex-shrink:0}
.breadcrumb-current{color:#111827;font-weight:600}
.show-title{font-size:1.625rem;font-weight:800;color:#111827;letter-spacing:-.02em;line-height:1.2;margin:0}
@media(min-width:768px){.show-title{font-size:2rem}}
.show-subtitle{font-size:.75rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#9ca3af;margin-top:.25rem}
.show-actions{display:flex;gap:.75rem;flex-wrap:wrap;flex-shrink:0;margin-top:.5rem}
@media(min-width:640px){.show-actions{margin-top:0}}
.action-btn{display:inline-flex;align-items:center;gap:.5rem;padding:.55rem 1.25rem;font-size:.8125rem;font-weight:600;letter-spacing:.02em;border-radius:9px;text-decoration:none;cursor:pointer;transition:all .18s ease;font-family:inherit;white-space:nowrap;border:1.5px solid transparent}
.action-btn--primary{color:#16a34a;background:#fff;border-color:#bbf7d0}
.action-btn--primary:hover{background:#f0fdf4;border-color:#86efac}
.action-btn--green{color:#fff;background:linear-gradient(135deg,#22c55e,#16a34a);border-color:transparent;box-shadow:0 2px 8px rgba(22,163,74,.25)}
.action-btn--green:hover{background:linear-gradient(135deg,#16a34a,#15803d);box-shadow:0 4px 14px rgba(22,163,74,.35);transform:translateY(-1px)}
.action-btn--ghost{color:#6b7280;background:#fff;border-color:#e5e7eb}
.action-btn--ghost:hover{background:#f9fafb;border-color:#d1d5db;color:#374151}
.action-btn-icon{width:14px;height:14px;opacity:.7;flex-shrink:0}
.show-grid{display:grid;gap:1.5rem}
.show-grid--single{grid-template-columns:1fr}
.show-grid--sidebar{grid-template-columns:1fr}
@media(min-width:1024px){.show-grid--sidebar{grid-template-columns:1fr 280px}}
.show-main,.show-sidebar{display:flex;flex-direction:column;gap:1.5rem}
.show-card{background:#fff;border-radius:14px;border:1px solid #f0f0f0;box-shadow:0 1px 3px rgba(0,0,0,.05),0 4px 20px rgba(0,0,0,.03);overflow:hidden}
.show-card-header{padding:1.25rem 1.5rem;border-bottom:1px solid #f3f4f6;display:flex;align-items:center;justify-content:space-between}
.show-card-title{font-size:.9375rem;font-weight:700;color:#111827;margin:0;letter-spacing:-.01em}
.detail-list{padding:1.5rem;display:grid;grid-template-columns:1fr;gap:1.5rem}
@media(min-width:640px){.detail-list{grid-template-columns:1fr 1fr}}
.detail-item{display:flex;flex-direction:column;gap:.375rem}
.detail-item--full{grid-column:1 / -1}
.detail-label{font-size:.6875rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#9ca3af}
.detail-value{font-size:.9rem;color:#111827;line-height:1.6}
.detail-value--strong{font-weight:700;font-size:1rem}
.detail-value--prose{color:#374151;white-space:pre-wrap}
.detail-value--mono{font-family:"Courier New",monospace;font-size:.8125rem;background:#f3f4f6;padding:.25rem .625rem;border-radius:6px;display:inline-block;color:#374151;border:1px solid #e5e7eb}
.detail-value--link{color:#16a34a;text-decoration:none;font-weight:600}
.detail-value--link:hover{color:#15803d}
.badge{display:inline-flex;align-items:center;gap:.375rem;padding:.25rem .75rem;border-radius:999px;font-size:.75rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase}
.badge--green{background:#dcfce7;color:#166534}
.badge--red{background:#fee2e2;color:#991b1b}
.badge--gray{background:#f3f4f6;color:#374151}
.people-grid{list-style:none;margin:0;padding:1.5rem;display:grid;grid-template-columns:1fr;gap:.875rem}
@media(min-width:640px){.people-grid{grid-template-columns:1fr 1fr}}
.person-card{display:flex;align-items:center;gap:.875rem;padding:.875rem 1rem;background:#f9fafb;border:1px solid #f0f0f0;border-radius:10px;transition:all .15s}
.person-card:hover{border-color:#bbf7d0;background:#f0fdf4}
.person-avatar{width:2.5rem;height:2.5rem;border-radius:50%;background:#dcfce7;color:#166534;font-weight:800;font-size:.8125rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;border:2px solid #bbf7d0}
.person-info{min-width:0}
.person-name{font-size:.875rem;font-weight:700;color:#111827;margin:0 0 .125rem}
.person-link{color:inherit;text-decoration:none}
.person-link:hover{color:#16a34a}
.person-email{font-size:.75rem;color:#9ca3af;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.stat-list{padding:1.25rem 1.5rem;display:flex;flex-direction:column;gap:1rem}
.stat-item{display:flex;align-items:baseline;justify-content:space-between;padding:.625rem .875rem;background:#f9fafb;border-radius:8px;border:1px solid #f0f0f0}
.stat-value{font-size:1.5rem;font-weight:800;color:#16a34a;font-family:"Georgia",serif}
.stat-label{font-size:.7rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#9ca3af}
.empty-state{padding:2.5rem 1.5rem;text-align:center;border:1.5px dashed #e5e7eb;border-radius:10px;margin:1.5rem;background:#fafafa}
.empty-state-icon{width:2.5rem;height:2.5rem;color:#d1d5db;margin:0 auto .75rem}
.empty-state-text{font-size:.875rem;color:#9ca3af;margin:0 0 .75rem}
.empty-state-link{font-size:.8125rem;font-weight:700;color:#16a34a;text-decoration:none;padding:.4rem .875rem;border:1.5px solid #bbf7d0;border-radius:7px;display:inline-flex;transition:all .15s}
.empty-state-link:hover{background:#f0fdf4}
.profile-card{display:flex;flex-direction:column;align-items:center;text-align:center;padding:2rem 1.5rem}
.profile-avatar{width:5rem;height:5rem;border-radius:50%;background:#dcfce7;color:#166534;font-weight:800;font-size:1.5rem;display:flex;align-items:center;justify-content:center;border:3px solid #bbf7d0;box-shadow:0 4px 12px rgba(22,163,74,.15);margin-bottom:1rem}
.profile-name{font-size:1.25rem;font-weight:800;color:#111827;margin:0 0 .25rem}
.profile-email{font-size:.8125rem;color:#9ca3af;margin:0 0 1rem}
.profile-divider{width:100%;border-top:1px solid #f3f4f6;margin:1rem 0}
.profile-meta{width:100%;display:flex;flex-direction:column;gap:.75rem;text-align:left}
.profile-meta-row{display:flex;justify-content:space-between;align-items:center}
.profile-meta-key{font-size:.75rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#9ca3af}
.profile-meta-val{font-size:.8125rem;font-weight:600;color:#111827}
.event-banner{border-radius:10px;overflow:hidden;max-height:300px}
.event-banner img{width:100%;height:100%;object-fit:cover;display:block}
.event-banner-empty{background:#f9fafb;border:1.5px dashed #e5e7eb;border-radius:10px;padding:3rem 1.5rem;text-align:center}
.event-banner-empty-icon{width:2.5rem;height:2.5rem;color:#d1d5db;margin:0 auto .625rem}
.event-banner-empty-text{font-size:.8125rem;color:#9ca3af}
.item-grid{list-style:none;margin:0;padding:1.5rem;display:grid;grid-template-columns:1fr;gap:.75rem}
@media(min-width:480px){.item-grid{grid-template-columns:1fr 1fr}}
@media(min-width:768px){.item-grid{grid-template-columns:1fr 1fr 1fr}}
.item-card{padding:.875rem 1rem;background:#fff;border:1px solid #e5e7eb;border-radius:10px;display:flex;flex-direction:column;gap:.375rem;transition:all .15s}
.item-card:hover{border-color:#bbf7d0;box-shadow:0 2px 8px rgba(22,163,74,.08)}
.item-card-header{display:flex;align-items:center;justify-content:space-between}
.item-card-name{font-size:.875rem;font-weight:700;color:#111827;text-decoration:none}
.item-card-name:hover{color:#16a34a}
.item-card-meta{font-size:.75rem;color:#9ca3af}
.status-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.status-dot--active{background:#22c55e}
.status-dot--inactive{background:#d1d5db}
.content-prose{padding:1.5rem;font-size:.9rem;color:#374151;line-height:1.8}
.content-empty{padding:3rem 1.5rem;text-align:center;border:1.5px dashed #e5e7eb;border-radius:10px;margin:1.5rem;color:#9ca3af;font-size:.875rem;background:#fafafa}
</style>
