<div class="px-4 sm:px-6 lg:px-8 py-8 w-full max-w-9xl mx-auto">

  <!-- Page header -->
  <div class="sm:flex sm:justify-between sm:items-center mb-8">
    <div class="mb-4 sm:mb-0">
      <h1 class="text-2xl md:text-3xl text-gray-800 font-bold tracking-tight">Blog Post: <%= @blog_post.title %></h1>
      <div class="mt-2 text-sm text-gray-500 flex items-center gap-2">
        <%= link_to "Blog Posts", admin_blog_posts_path, class: "hover:text-green-600 transition-colors" %>
        <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-gray-900 font-medium truncate"><%= @blog_post.title %></span>
      </div>
    </div>
    
    <div class="grid grid-flow-col sm:auto-cols-max justify-start sm:justify-end gap-3">
      <%= link_to edit_admin_blog_post_path(@blog_post), class: "btn bg-white border-green-200 hover:border-green-300 text-green-600 shadow-sm" do %>
        <svg class="w-4 h-4 fill-current opacity-50 shrink-0 mr-2" viewBox="0 0 16 16">
          <path d="M11.7.3c-.4-.4-1-.4-1.4 0l-10 10c-.2.2-.3.4-.3.7v4c0 .6.4 1 1 1h4c.3 0 .5-.1.7-.3l10-10c.4-.4.4-1 0-1.4l-4-4zM4.6 14H2v-2.6l6-6L10.6 8l-6 6zM12 6.6L9.4 4 11 2.4 13.6 5 12 6.6z" />
        </svg>
        <span class="hidden xs:block ml-2">Edit Post</span>
      <% end %>
      <a href="<%= blog_post_path(@blog_post) %>" target="_blank" class="btn bg-green-600 hover:bg-green-700 text-white shadow-sm">
        <svg class="w-4 h-4 fill-current opacity-50 shrink-0 mr-2" viewBox="0 0 16 16">
          <path d="M15 15H1V1h7V0H0v16h16V8h-1v7z" />
          <path d="M10 0v1h4.3L6.6 8.6l.7.7L15 1.7V6h1V0z" />
        </svg>
        <span class="hidden xs:block ml-2">View Live</span>
      </a>
    </div>
  </div>

  <div class="grid grid-cols-1 xl:grid-cols-3 gap-8 mb-8">
    <!-- Left column: Main Content -->
    <div class="xl:col-span-2 space-y-8">
      
      <div class="bg-white shadow-sm rounded-xl border border-gray-200 p-6 overflow-hidden">
        <div class="border-b border-gray-100 pb-4 mb-4">
          <h2 class="text-lg font-semibold text-gray-800">Article Content</h2>
        </div>
        
        <div class="prose max-w-none text-gray-900">
          <% if @blog_post.body.present? %>
            <%= @blog_post.body %>
          <% else %>
            <div class="text-center py-12 text-gray-400 border border-dashed border-gray-200 rounded-lg">
              No content has been written for this post yet.
            </div>
          <% end %>
        </div>
      </div>
      
    </div>
    
    <!-- Right column: Metadata -->
    <div class="xl:col-span-1 space-y-8">
      
      <div class="bg-white shadow-sm rounded-xl border border-gray-200 p-6">
        <h3 class="text-lg font-semibold text-gray-800 border-b border-gray-100 pb-4 mb-4">Publication Details</h3>
        <dl class="space-y-6">
          <div>
            <dt class="text-sm font-medium text-gray-500 uppercase tracking-wide">Status</dt>
            <dd class="mt-1">
              <% if @blog_post.published_at.present? && @blog_post.published_at <= Time.current %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Published</span>
              <% elsif @blog_post.published_at.present? && @blog_post.published_at > Time.current %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-secondary text-primary">Scheduled</span>
              <% else %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Draft</span>
              <% end %>
            </dd>
          </div>
          
          <div>
            <dt class="text-sm font-medium text-gray-500 uppercase tracking-wide">Author</dt>
            <dd class="mt-1 flex items-center">
              <% if @blog_post.author %>
                <div class="h-6 w-6 rounded-full bg-green-100 flex items-center justify-center text-green-700 font-bold mr-2 text-xs shrink-0">
                  <%= @blog_post.author.initials %>
                </div>
                <%= link_to @blog_post.author.full_name, admin_user_path(@blog_post.author), class: "text-green-600 hover:text-green-800 text-sm font-medium" %>
              <% else %>
                <span class="text-gray-400 text-sm">Unknown Author</span>
              <% end %>
            </dd>
          </div>

          <div>
            <dt class="text-sm font-medium text-gray-500 uppercase tracking-wide">Publish Date</dt>
            <dd class="mt-1 text-sm text-gray-900 font-medium">
              <%= @blog_post.published_at&.strftime("%b %d, %Y at %l:%M %p") || "Not set" %>
            </dd>
          </div>
          
          <div>
            <dt class="text-sm font-medium text-gray-500 uppercase tracking-wide">Created</dt>
            <dd class="mt-1 text-sm text-gray-500"><%= time_ago_in_words(@blog_post.created_at) %> ago</dd>
          </div>
        </dl>
      </div>
      
    </div>
  </div>
</div>
