<%= form_with(model: [:admin, user], class: "space-y-6") do |form| %>
  <% if user.errors.any? %>
    <div class="bg-red-50 p-4 rounded-md">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(user.errors.count, "error") %> prohibited this user from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul role="list" class="list-disc pl-5 space-y-1">
              <% user.errors.each do |error| %>
                <li><%= error.full_message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-2">
    <div>
      <%= form.label :first_name, class: "block text-sm font-medium text-gray-700" %>
      <div class="mt-1">
        <%= form.text_field :first_name, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
      </div>
    </div>

    <div>
      <%= form.label :last_name, class: "block text-sm font-medium text-gray-700" %>
      <div class="mt-1">
        <%= form.text_field :last_name, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
      </div>
    </div>
  </div>

  <div>
    <%= form.label :email, class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <%= form.email_field :email, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
    </div>
  </div>

  <div>
    <%= form.label :phone, "Phone number", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <%= form.text_field :phone, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
    </div>
  </div>

  <div>
    <%= form.label :role, class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <%= form.select :role, User.role_options_for_select, {}, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md", id: "user_role_select" %>
    </div>
  </div>

  <div id="directorate-field" class="<%= user.directorate_director? ? '' : 'hidden' %>">
    <%= form.label :directorate_id, class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <%= form.collection_select :directorate_id, Directorate.all.order(:name), :id, :name, { include_blank: "Select Directorate" }, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
    </div>
  </div>

  <div id="state-field" class="<%= (user.state_admin? || user.state_secretary?) ? '' : 'hidden' %>">
    <%= form.label :state_id, class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <%= form.collection_select :state_id, State.all.order(:name), :id, :name, { include_blank: "Select State" }, class: "shadow-sm focus:ring-green-500 focus:border-green-500 block w-full sm:text-sm border-gray-300 rounded-md" %>
    </div>
  </div>

  <div class="flex justify-end pt-5">
    <%= link_to "Cancel", admin_users_path(role: user.role), class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 mr-3" %>
    <%= form.submit class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
  </div>
<% end %>

<script>
  (function() {
    function initUserForm() {
      const roleSelect = document.getElementById("user_role_select");
      const directorateField = document.getElementById("directorate-field");
      const stateField = document.getElementById("state-field");

      if (!roleSelect || !directorateField || !stateField) return;

      function toggleFields() {
        const role = roleSelect.value;
        
        if (role === "directorate_director") {
          directorateField.classList.remove("hidden");
          stateField.classList.add("hidden");
        } else if (role === "state_admin" || role === "state_secretary") {
          stateField.classList.remove("hidden");
          directorateField.classList.add("hidden");
        } else {
          directorateField.classList.add("hidden");
          stateField.classList.add("hidden");
        }
      }

      roleSelect.addEventListener("change", toggleFields);
      // Run once on load to set initial state
      toggleFields();
    }

    // Run on direct load
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initUserForm);
    } else {
      initUserForm();
    }
    
    // Run on Turbo navigation
    document.addEventListener("turbo:load", initUserForm);
  })();
</script>
