<div class="form-card">
  <%= form_with(model: [:admin, state], class: "directorate-form") do |form| %>
    <% if state.errors.any? %>
      <div class="error-banner">
        <div class="error-icon-wrap">
          <svg class="error-icon" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="error-body">
          <h3 class="error-title"><%= pluralize(state.errors.count, "error") %> detected</h3>
          <ul class="error-list">
            <% state.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    <% end %>

    <div class="form-fields">
      <div class="field-group">
        <%= form.label :name, class: "field-label" %>
        <div class="field-hint">The full official name of this state</div>
        <%= form.text_field :name, placeholder: "e.g. Lagos", class: "field-input" %>
      </div>

      <div class="form-row">
        <div class="field-group">
          <%= form.label :code, "State Code", class: "field-label" %>
          <div class="field-hint">Short identifier code for this state</div>
          <%= form.text_field :code, placeholder: "e.g. LAG", class: "field-input" %>
        </div>
        <div class="field-group">
          <%= form.label :zone_id, "Region / Zone", class: "field-label" %>
          <div class="field-hint">The geopolitical zone this state belongs to</div>
          <%= form.select :zone_id,
              Zone.order(:name).map { |z| [z.name, z.id] },
              { include_blank: "— Select Zone —" },
              class: "field-input field-select" %>
        </div>
      </div>

      <div class="field-group">
        <%= form.label :year_created, "Year Established", class: "field-label" %>
        <div class="field-hint">The year this state chapter was formally established</div>
        <%= form.number_field :year_created, min: 1980, max: Date.current.year, placeholder: "YYYY", class: "field-input" %>
      </div>

      <div class="field-group">
        <%= form.label :description, class: "field-label" %>
        <div class="field-hint">A brief historical or operational overview of this state</div>
        <%= form.text_area :description, rows: 5, placeholder: "Brief historical or operational overview...", class: "field-input field-textarea" %>
      </div>

      <% if state.persisted? %>
        <div class="info-banner">
          <svg class="info-banner-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <%= link_to "Manage Operational Areas (#{state.areas.count})", admin_state_areas_path(state), class: "info-banner-link" %>
        </div>
      <% end %>
    </div>

    <div class="form-actions">
      <%= link_to admin_states_path, class: "btn-cancel" do %>
        <svg viewBox="0 0 20 20" fill="currentColor" class="btn-icon">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
        Cancel
      <% end %>
      <%= form.submit state.new_record? ? "Create State" : "Update State", class: "btn-submit" %>
    </div>
  <% end %>
</div>

<style>
  .form-card { background:#fff; border-radius:16px; box-shadow:0 1px 3px rgba(0,0,0,.06),0 4px 24px rgba(0,0,0,.04); border:1px solid #f0f0f0; padding:2.5rem; font-family:'Georgia',serif; }
  .error-banner { display:flex; gap:.875rem; background:#fff5f5; border:1px solid #fecaca; border-left:4px solid #ef4444; border-radius:10px; padding:1rem 1.25rem; margin-bottom:2rem; }
  .error-icon-wrap { flex-shrink:0; padding-top:1px; }
  .error-icon { width:18px; height:18px; color:#ef4444; }
  .error-title { font-size:.8125rem; font-weight:700; color:#991b1b; margin:0 0 .375rem; letter-spacing:.01em; }
  .error-list { margin:0; padding-left:1.125rem; font-size:.8125rem; color:#b91c1c; line-height:1.6; }
  .form-fields { display:flex; flex-direction:column; gap:2rem; }
  .form-row { display:grid; grid-template-columns:1fr 1fr; gap:1.25rem; }
  @media(max-width:540px){ .form-row { grid-template-columns:1fr; } }
  .field-group { display:flex; flex-direction:column; }
  .field-label { display:block; font-size:.6875rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:#374151; margin-bottom:.375rem; }
  .field-hint { font-size:.8rem; color:#9ca3af; margin-bottom:.75rem; font-style:italic; font-family:'Georgia',serif; line-height:1.4; }
  .field-input { display:block; width:100%; padding:.75rem 1rem; background:#f9fafb; border:1.5px solid #22c55e; border-radius:10px; font-size:.9rem; color:#111827; font-family:inherit; line-height:1.5; transition:border-color .18s ease,background .18s ease,box-shadow .18s ease; box-sizing:border-box; outline:none; appearance:none; }
  .field-input::placeholder { color:#b0bec5; font-style:italic; }
  .field-input:hover { border-color:#16a34a; background:#fff; }
  .field-input:focus { background:#fff; border-color:#16a34a; box-shadow:0 0 0 4px rgba(34,197,94,.1); }
  .field-textarea { resize:vertical; min-height:120px; }
  .field-select { cursor:pointer; }
  .info-banner { display:flex; align-items:center; gap:.875rem; background:#f0fdf4; border:1px solid #bbf7d0; border-radius:10px; padding:.875rem 1.25rem; }
  .info-banner-icon { width:18px; height:18px; color:#16a34a; flex-shrink:0; }
  .info-banner-link { font-size:.8375rem; font-weight:700; color:#15803d; text-decoration:none; letter-spacing:.01em; }
  .info-banner-link:hover { color:#166534; }
  .form-actions { display:flex; align-items:center; justify-content:flex-end; gap:.875rem; margin-top:2.5rem; padding-top:2rem; border-top:1px solid #f3f4f6; }
  .btn-cancel { display:inline-flex; align-items:center; gap:.4rem; padding:.65rem 1.375rem; font-size:.8375rem; font-weight:600; letter-spacing:.02em; color:#6b7280; background:transparent; border:1.5px solid #e5e7eb; border-radius:9px; text-decoration:none; cursor:pointer; transition:all .18s ease; font-family:inherit; }
  .btn-cancel:hover { color:#374151; background:#f9fafb; border-color:#d1d5db; }
  .btn-cancel:active { transform:scale(.98); }
  .btn-icon { width:14px; height:14px; opacity:.7; }
  .btn-submit { display:inline-flex; align-items:center; padding:.7rem 1.75rem; font-size:.8375rem; font-weight:700; letter-spacing:.04em; text-transform:uppercase; color:#fff; background:linear-gradient(135deg,#22c55e 0%,#16a34a 100%); border:none; border-radius:9px; box-shadow:0 2px 8px rgba(22,163,74,.3),0 1px 2px rgba(0,0,0,.08); cursor:pointer; transition:all .18s ease; font-family:inherit; }
  .btn-submit:hover { background:linear-gradient(135deg,#16a34a 0%,#15803d 100%); box-shadow:0 4px 14px rgba(22,163,74,.4),0 2px 4px rgba(0,0,0,.1); transform:translateY(-1px); }
  .btn-submit:active { transform:scale(.98) translateY(0); box-shadow:0 1px 4px rgba(22,163,74,.3); }
  .btn-submit:focus { outline:none; box-shadow:0 0 0 4px rgba(34,197,94,.25),0 2px 8px rgba(22,163,74,.3); }
</style>
