<div class="px-4 sm:px-6 lg:px-8 py-8 w-full max-w-9xl mx-auto">

  <!-- Page header -->
  <div class="sm:flex sm:justify-between sm:items-center mb-8">
    <div class="mb-4 sm:mb-0">
      <h1 class="text-2xl md:text-3xl text-gray-800 font-bold tracking-tight">Donation Details</h1>
      <div class="mt-2 text-sm text-gray-500 flex items-center gap-2">
        <%= link_to "Donations", admin_donations_path, class: "hover:text-green-600 transition-colors" %>
        <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-gray-900 font-medium truncate"><%= @donation.payment_reference || "Donation ##{@donation.id}" %></span>
      </div>
    </div>
    
    <div class="grid grid-flow-col sm:auto-cols-max justify-start sm:justify-end gap-3">
      <%= link_to edit_admin_donation_path(@donation), class: "btn bg-white border-green-200 hover:border-green-300 text-green-600 shadow-sm" do %>
        <svg class="w-4 h-4 fill-current opacity-50 shrink-0 mr-2" viewBox="0 0 16 16">
          <path d="M11.7.3c-.4-.4-1-.4-1.4 0l-10 10c-.2.2-.3.4-.3.7v4c0 .6.4 1 1 1h4c.3 0 .5-.1.7-.3l10-10c.4-.4.4-1 0-1.4l-4-4zM4.6 14H2v-2.6l6-6L10.6 8l-6 6zM12 6.6L9.4 4 11 2.4 13.6 5 12 6.6z" />
        </svg>
        <span class="hidden xs:block ml-2">Edit Donation</span>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 xl:grid-cols-3 gap-8 mb-8">
    
    <div class="xl:col-span-2 space-y-8">
      <div class="bg-white shadow-sm rounded-xl border border-gray-200 p-6">
        <div class="border-b border-gray-100 pb-4 mb-4">
          <h2 class="text-lg font-semibold text-gray-800">Transaction Information</h2>
        </div>

        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-8">
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500 uppercase tracking-wide">Donor Email</dt>
            <dd class="mt-1 text-base text-gray-900 font-semibold"><a href="mailto:<%= @donation.donor_email %>" class="text-green-600 hover:underline"><%= @donation.donor_email %></a></dd>
          </div>
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500 uppercase tracking-wide">Purpose</dt>
            <dd class="mt-1 text-base text-gray-900"><%= @donation.purpose.presence || "General Donation" %></dd>
          </div>
          
          <div class="sm:col-span-1 border-t border-gray-100 pt-6">
            <dt class="text-sm font-medium text-gray-500 uppercase tracking-wide">Amount</dt>
            <dd class="mt-1 text-2xl font-bold text-gray-900">
              <%= @donation.currency || "NGN" %> <%= number_to_currency(@donation.amount, unit: "") %>
            </dd>
          </div>
          <div class="sm:col-span-1 border-t border-gray-100 pt-6">
            <dt class="text-sm font-medium text-gray-500 uppercase tracking-wide">Status</dt>
            <dd class="mt-1">
              <% case @donation.status&.to_s %>
              <% when 'successful' %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">Successful</span>
              <% when 'failed' %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-red-100 text-red-800">Failed</span>
              <% when 'pending' %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-yellow-100 text-yellow-800">Pending</span>
              <% else %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-800"><%= @donation.status&.titleize || "Unknown" %></span>
              <% end %>
            </dd>
          </div>

          <div class="sm:col-span-2 border-t border-gray-100 pt-6">
            <dt class="text-sm font-medium text-gray-500 uppercase tracking-wide">Payment Reference</dt>
            <dd class="mt-1 text-base text-gray-900 font-mono bg-gray-50 p-2 rounded w-max border border-gray-200"><%= @donation.payment_reference.presence || "Manual Entry" %></dd>
          </div>
        </dl>
      </div>
    </div>
    
    <div class="xl:col-span-1 space-y-8">
      <div class="bg-white shadow-sm rounded-xl border border-gray-200 p-6">
        <h3 class="text-lg font-semibold text-gray-800 border-b border-gray-100 pb-4 mb-4">Metadata</h3>
        <dl class="space-y-6">
          <div>
            <dt class="text-sm font-medium text-gray-500 uppercase tracking-wide">Transaction Date</dt>
            <dd class="mt-1 text-sm text-gray-900 font-medium">
              <%= @donation.created_at.strftime("%b %d, %Y at %l:%M %p") %>
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500 uppercase tracking-wide">Last Updated</dt>
            <dd class="mt-1 text-sm text-gray-500">
              <%= time_ago_in_words(@donation.updated_at) %> ago
            </dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500 uppercase tracking-wide">Internal ID</dt>
            <dd class="mt-1 text-sm text-gray-500 font-mono">
              #<%= @donation.id %>
            </dd>
          </div>
        </dl>
      </div>
    </div>
    
  </div>
</div>
