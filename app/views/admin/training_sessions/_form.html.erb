<div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
  <%= form_with(model: [:admin, training, training_session], class: "space-y-8") do |form| %>
    <div class="grid grid-cols-1 gap-y-12 gap-x-6 sm:grid-cols-2">
      <div class="sm:col-span-2">
        <%= form.label :title, class: "block text-xs font-bold text-gray-400 uppercase tracking-widest ml-1 mb-3" %>
        <%= form.text_field :title, placeholder: "e.g. Session 1: Introduction", class: "block w-full px-4 py-3 bg-gray-50 border border-green-500 rounded-xl text-gray-900 focus:bg-white focus:ring-4 focus:ring-green-600/10 focus:border-green-600 transition-all duration-200 sm:text-sm" %>
      </div>

      <div>
        <%= form.label :duration, "Duration (minutes)", class: "block text-xs font-bold text-gray-400 uppercase tracking-widest ml-1 mb-3" %>
        <%= form.number_field :duration, placeholder: "e.g. 45", class: "block w-full px-4 py-3 bg-gray-50 border border-green-500 rounded-xl text-gray-900 focus:bg-white focus:ring-4 focus:ring-green-600/10 focus:border-green-600 transition-all duration-200 sm:text-sm" %>
      </div>

      <div class="sm:col-span-2">
        <%= form.label :media_url, "Media URL (Video/Audio)", class: "block text-xs font-bold text-gray-400 uppercase tracking-widest ml-1 mb-3" %>
        <%= form.text_field :media_url, placeholder: "https://youtube.com/...", class: "block w-full px-4 py-3 bg-gray-50 border border-green-500 rounded-xl text-gray-900 focus:bg-white focus:ring-4 focus:ring-green-600/10 focus:border-green-600 transition-all duration-200 sm:text-sm" %>
      </div>
    </div>

    <div class="flex items-center justify-end pt-8 border-t border-gray-50 gap-4">
      <%= link_to "Cancel", admin_training_path(training), class: "px-6 py-3 text-sm font-semibold text-gray-500 hover:text-gray-700 transition-colors" %>
      <%= form.submit training_session.new_record? ? "Add Session" : "Update Session", class: "px-8 py-3 bg-green-600 text-white text-sm font-bold rounded-xl shadow-lg shadow-green-600/20 hover:bg-green-700 hover:shadow-green-600/30 focus:ring-4 focus:ring-green-600/20 active:scale-[0.98] transition-all cursor-pointer" %>
    </div>
  <% end %>
</div>
