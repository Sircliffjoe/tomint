<% content_for :title, @post.title %>

<div class="bg-white px-6 py-32 lg:px-8">
  <div class="mx-auto max-w-3xl text-base leading-7 text-gray-700">
    <div class="mb-8">
      <%= link_to "← Back to Blog", blog_index_path, class: "text-sm font-semibold leading-6 text-green-600 hover:text-green-500" %>
    </div>
    
    <p class="text-base font-semibold leading-7 text-green-600"><%= @post.published_at.strftime("%B %d, %Y") %></p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl"><%= @post.title %></h1>
    
    <div class="mt-6 flex items-center gap-x-4">
      <div class="text-sm leading-6">
        <p class="font-semibold text-gray-900">
          By <%= @post.author.first_name %> <%= @post.author.last_name %>
        </p>
      </div>
    </div>

    <div class="mt-10 prose prose-lg text-gray-500">
      <%= @post.body %>
    </div>
  </div>
</div>
