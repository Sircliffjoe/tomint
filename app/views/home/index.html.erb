<% content_for :title, "Welcome to TOM Int." %>

<div class="bg-gradient-to-b from-green-100 via-white to-white relative overflow-hidden">
  
  <!-- Hero Section -->
  <div class="relative isolate pt-14">
    <div class="absolute inset-0 -z-30 bg-[radial-gradient(ellipse_at_top,_rgba(22,163,74,0.08),_transparent_60%)]"></div>

    <!-- Blurred Gradients -->
    <div class="absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-80" aria-hidden="true">
      <div class="relative left-[calc(50%-11rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 rotate-[30deg] bg-gradient-to-tr from-leaf-100 via-leaf-300 to-leaf-600 opacity-25 sm:left-[calc(50%-30rem)] sm:w-[72.1875rem]" style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)"></div>
    </div>

    <div class="py-24 sm:py-32 lg:pb-40">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <div class="mb-8 flex justify-center">
            <div class="relative rounded-full px-4 py-1.5 text-sm leading-6 text-gray-700 ring-1 ring-gray-900/10 hover:ring-leaf-500/50 bg-white/60 backdrop-blur-md shadow-sm transition-all hover:bg-white/80">
              Impact. Discipleship. Leadership. <a href="<%= about_path %>" class="font-semibold text-leaf-600"><span class="absolute inset-0" aria-hidden="true"></span>Read our story <span aria-hidden="true">&rarr;</span></a>
            </div>
          </div>
          <h1 class="text-4xl font-extrabold tracking-tight text-gray-900 sm:text-6xl leading-tight">
            Raising Leaders. <br>
            <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(to right, #14532d, #16a34a); -webkit-background-clip: text; background-clip: text; color: transparent;">Impacting Generations.</span>
          </h1>
          <p class="mt-6 text-lg leading-8 text-gray-600">
            Mentoring teenagers in Christ, building leaders through faith-based training, and reaching the next generation since 1992.
            We are excited to see what the future holds as we continue to reach out to teenagers and make a difference in their lives.
          </p>
          <div class="mt-10 flex items-center justify-center gap-x-6">
            <%= link_to "Join Our Mission", new_user_registration_path, class: "rounded-lg bg-leaf-600 px-6 py-3.5 text-sm font-semibold text-white shadow-lg shadow-leaf-600/30 hover:bg-leaf-500 hover:shadow-leaf-600/50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-leaf-600 transition-all transform hover:-translate-y-0.5" %>
            <%= link_to "Live Events", events_path, class: "text-sm font-semibold leading-6 text-gray-900 flex items-center gap-1 group bg-white/50 px-4 py-3 rounded-lg hover:bg-white/80 backdrop-blur-sm transition-all" %>
              See what's happening <span aria-hidden="true" class="group-hover:translate-x-1 transition-transform">&rarr;</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Gradient Bottom Blur -->
    <div class="absolute inset-x-0 top-[calc(100%-13rem)] -z-10 transform-gpu overflow-hidden blur-3xl sm:top-[calc(100%-30rem)]" aria-hidden="true">
      <div class="relative left-[calc(50%+3rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 bg-gradient-to-tr from-leaf-200 to-leaf-600 opacity-20 sm:left-[calc(50%+36rem)] sm:w-[72.1875rem]" style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)"></div>
    </div>
  </div>

  <!-- Hero END -->

  <!-- Four Pillars Section -->
  <div class="relative z-20 -mt-24 pb-24 mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 shadow-xl">
      
      <!-- Card 1: Our Vision -->
      <div class="bg-leaf-100 p-8 lg:p-10 flex flex-col items-center text-center group transition-colors duration-300">
        <div class="mb-6">
           <svg class="w-16 h-16 text-leaf-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
             <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
             <!-- Additional subtle elements for "people" could be added but globe conveys 'all nations' well -->
             <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" class="hidden" /> <!-- Hidden extra for simplicity -->
           </svg>
        </div>
        <h3 class="text-xl font-serif font-bold text-leaf-900 mb-4">Our Vision</h3>
        <p class="text-gray-500 text-sm leading-relaxed mb-8 flex-grow">
          To share the gospel of Christ with teenagers of all Nations and disciple them unto maturity in the Christian faith.
        </p>
        <a href="<%= about_path %>" class="inline-block text-leaf-50 text-xs font-bold py-3 px-8 uppercase tracking-wider transition-colors">
          Learn More
        </a>
      </div>

      <!-- Card 2: Our Conviction -->
      <div class="bg-leaf-50 p-8 lg:p-10 flex flex-col items-center text-center border-l border-gray-100 group transition-colors duration-300">
        <div class="mb-6">
           <svg class="w-16 h-16 text-leaf-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
             <path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" class="hidden"/>
             <path stroke-linecap="round" stroke-linejoin="round" d="M7 11.5V14m0-2.5v-6a1.5 1.5 0 113 0m-3 6a1.5 1.5 0 00-3 0v2a7.5 7.5 0 0015 0v-5a1.5 1.5 0 00-3 0m-6-3V11m0-5.5v-1a1.5 1.5 0 013 0v1m0 0V11m0-5.5a1.5 1.5 0 013 0v3m0 0V11" /> <!-- Handshake approx -->
           </svg>
        </div>
        <h3 class="text-xl font-serif font-bold text-leaf-900 mb-4">Our Conviction</h3>
        <p class="text-gray-500 text-sm leading-relaxed mb-8 flex-grow">
          Is that through a flexible and dynamic fellowship devoid of denominational traditions such as the Teenagers’ Club...
        </p>
         <a href="<%= about_path %>" class="inline-block text-leaf-50 text-xs font-bold py-3 px-8 uppercase tracking-wider transition-colors">
          Learn More
        </a>
      </div>

      <!-- Card 3: Our Strategy (Green) -->
      <div class="bg-leaf-950 p-8 lg:p-10 flex flex-col items-center text-center text-white">
        <div class="mb-6">
           <svg class="w-16 h-16 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
             <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
             <!-- Hand holding money icon approximation -->
             <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" class="hidden" />
           </svg>
        </div>
        <h3 class="text-xl font-serif font-bold mb-4">Our Strategy</h3>
        <p class="text-white/90 text-sm leading-relaxed mb-8 flex-grow">
          Among other supportive programmes, is to establish a Teenagers’ Club in every neighbourhood...
        </p>
        <a href="<%= about_path %>" class="inline-block text-white text-xs font-bold py-3 px-8 uppercase tracking-wider transition-colors">
          Learn More
        </a>
      </div>

      <!-- Card 4: Image -->
      <div class="relative h-full min-h-[300px] lg:min-h-0">
        <%= image_tag "/hero.jpg", class: "absolute inset-0 w-full h-full object-cover", alt: "Teenagers smiling" %>
        <!-- Overlay gradient if needed -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
      </div>

    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════ -->
  <!-- SECTION 2: WHAT WE DO (OUR PROGRAMMES)             -->
  <!-- ═══════════════════════════════════════════════════ -->
  <div class="py-24 sm:py-32 bg-stone-50">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-sm font-bold text-leaf-600 uppercase tracking-[0.35em]">What We Do</h2>
        <p class="mt-3 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl font-serif">Our Programmes</p>
        <p class="mt-4 text-[15px] leading-7 text-gray-600">Explore programmes designed to nurture, empower, and equip teenagers with godly values, leadership skills, and spiritual growth.</p>
      </div>

      <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-8 lg:mx-0 lg:max-w-none lg:grid-cols-3">
        <!-- Card 1: Outreach -->
        <div class="bg-white rounded-2xl shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden group border border-gray-100">
          <div class="h-56 overflow-hidden">
            <%= image_tag "/about_1.png", class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500", alt: "Outreach programmes" %>
          </div>
          <div class="p-6">
            <h3 class="text-lg font-bold text-gray-900 uppercase tracking-wide">Outreach</h3>
            <p class="mt-3 text-sm leading-6 text-gray-600">Through dynamic programmes like Teenagers' Clubs, Vacation Camps, and School Seminars, we reach teenagers in their everyday environments.</p>
            <div class="mt-5">
              <%= link_to "Learn More", events_path, class: "inline-block rounded-md bg-leaf-600 px-5 py-2.5 text-xs font-bold text-white uppercase tracking-wider hover:bg-leaf-500 shadow-sm transition-all" %>
            </div>
          </div>
        </div>

        <!-- Card 2: Training -->
        <div class="bg-white rounded-2xl shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden group border border-gray-100">
          <div class="h-56 overflow-hidden">
            <%= image_tag "/about_2.png", class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500", alt: "Training programmes" %>
          </div>
          <div class="p-6">
            <h3 class="text-lg font-bold text-gray-900 uppercase tracking-wide">Training</h3>
            <p class="mt-3 text-sm leading-6 text-gray-600">TOM lays a lot of emphasis on training. No one can do well, what he or she has not been trained to do. We equip workers and leaders.</p>
            <div class="mt-5">
              <%= link_to "Learn More", trainings_path, class: "inline-block rounded-md bg-leaf-600 px-5 py-2.5 text-xs font-bold text-white uppercase tracking-wider hover:bg-leaf-500 shadow-sm transition-all" %>
            </div>
          </div>
        </div>

        <!-- Card 3: Discipleship -->
        <div class="bg-white rounded-2xl shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden group border border-gray-100">
          <div class="h-56 overflow-hidden">
            <%= image_tag "/about_3.png", class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500", alt: "Discipleship programmes" %>
          </div>
          <div class="p-6">
            <h3 class="text-lg font-bold text-gray-900 uppercase tracking-wide">Discipleship</h3>
            <p class="mt-3 text-sm leading-6 text-gray-600">These are programmes aimed at getting our teens to become Christ centered and balanced adults who are pillars in their generation.</p>
            <div class="mt-5">
              <%= link_to "Learn More", about_path, class: "inline-block rounded-md bg-leaf-600 px-5 py-2.5 text-xs font-bold text-white uppercase tracking-wider hover:bg-leaf-500 shadow-sm transition-all" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════ -->
  <!-- SECTION 4: UPCOMING EVENTS                         -->
  <!-- ═══════════════════════════════════════════════════ -->
  <div class="py-24 mt-tp bg-white relative">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-sm font-bold text-leaf-600 uppercase tracking-[0.35em]">Don't Miss Out</h2>
        <p class="mt-3 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl font-serif">Upcoming Events</p>
        <p class="mt-4 text-[15px] leading-7 text-gray-600">Be part of what's coming next! Join us for impactful camps, trainings, and outreaches designed to empower and inspire.</p>
      </div>

      <div class="mx-auto mt-16 max-w-7xl">
        <% if @upcoming_events.present? %>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% @upcoming_events.each do |event| %>
              <%= link_to event_path(event),
                class: "group relative block overflow-hidden rounded-3xl bg-neutral-900 shadow-lg transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl" do %>

                <!-- Background image -->
                <div class="absolute inset-0">
                  <% if event.image.attached? %>
                    <%= image_tag event.image,
                      class: "h-full w-full object-cover transition-transform duration-700 group-hover:scale-110",
                      alt: event.title %>
                  <% else %>
                    <div class="h-full w-full bg-gradient-to-br from-leaf-800 to-leaf-950"></div>
                  <% end %>
                </div>

                <!-- Gradient overlay — cinematic bottom fade -->
                <div class="absolute inset-0 bg-gradient-to-t from-leaf/80 via-leaf/40 to-leaf/10 group-hover:from-leaf/85"></div>

                <!-- Top accent bar on hover -->
                <div class="absolute top-0 inset-x-0 h-1 bg-leaf-500 transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>

                <!-- Glow border -->
                <div class="absolute inset-0 rounded-3xl ring-1 ring-white/10 group-hover:ring-white/20 transition-all"></div>

                <!-- Date badge — top left -->
                <div class="absolute top-4 left-4 z-10">
                  <div class="bg-white rounded-xl text-center shadow-lg overflow-hidden" style="width:56px;">
                    <div class="bg-leaf-600 text-white text-[10px] font-bold uppercase tracking-wider py-1">
                      <%= event.start_time.strftime("%b") %>
                    </div>
                    <div class="py-1.5">
                      <span class="text-xl font-extrabold text-gray-900 leading-none"><%= event.start_time.strftime("%d") %></span>
                    </div>
                  </div>
                </div>

                <!-- Free/Paid badge — top right -->
                <div class="absolute top-4 right-4 z-10">
                  <% if event.free? %>
                    <span class="inline-flex items-center rounded-full bg-leaf-500/90 px-3 py-1 text-[11px] font-bold text-white uppercase tracking-wider backdrop-blur-sm">
                      Free
                    </span>
                  <% else %>
                    <span class="inline-flex items-center rounded-full bg-amber-500/90 px-3 py-1 text-[11px] font-bold text-white uppercase tracking-wider backdrop-blur-sm">
                      <%= event.currency %> <%= number_with_delimiter(event.price.to_i) %>
                    </span>
                  <% end %>
                </div>

                <!-- Content -->
                <div class="relative flex flex-col justify-end p-6" style="height: 24rem;">

                  <!-- Glass panel -->
                  <div class="rounded-2xl backdrop-blur-md border border-white/15 p-5 transition-all duration-300" style="background: rgba(0,0,0,0.55);">

                    <h3 class="text-lg font-bold text-white leading-snug line-clamp-2">
                      <%= event.title %>
                    </h3>

                    <% if event.location.present? %>
                      <div class="mt-2 flex items-center gap-2 text-white">
                        <svg style="width:14px;height:14px;min-width:14px;" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z"/></svg>
                        <span class="text-xs truncate"><%= event.location %></span>
                      </div>
                    <% end %>

                    <div class="mt-4 flex items-center justify-between">
                      <span class="text-sm font-medium text-white group-hover:text-white transition-colors">
                        View event
                      </span>
                      <span class="inline-flex items-center justify-center rounded-full bg-leaf-600 text-white transition-all duration-300 group-hover:translate-x-1 group-hover:bg-leaf-500" style="width:40px;height:40px;">
                        <svg style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
                      </span>
                    </div>

                  </div>
                </div>
              <% end %>
            <% end %>
          </div>

          <div class="mt-tt text-center">
            <%= link_to "All Events", events_path, class: "rounded-lg bg-leaf-600 px-6 py-3.5 text-sm font-semibold text-white shadow-lg shadow-leaf-600/30 hover:bg-leaf-500 hover:shadow-leaf-600/50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-leaf-600 transition-all transform hover:-translate-y-0.5" %>
          </div>
        <% else %>
          <div class="text-center py-16 bg-gray-50 rounded-2xl">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
            <h3 class="mt-4 text-lg font-semibold text-gray-900">No upcoming events</h3>
            <p class="mt-2 text-sm text-gray-500">Check back soon for exciting events and programmes.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>


  <!-- ═══════════════════════════════════════════════════ -->
  <!-- SECTION: TESTIMONIALS                              -->
  <!-- ═══════════════════════════════════════════════════ -->
  <div class="py-20 mt-tt sm:py-24 relative overflow-hidden">
    
    <div class="mx-auto max-w-7xl px-6 lg:px-8 relative z-10">
      <div class="text-center mb-14">
        <span class="text-sm font-semibold tracking-widest text-leaf-600 uppercase">
          Testimonials
        </span>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          What People are Saying
        </h2>
        <p class="mt-4 text-gray-600">
          Here’s what people are saying about their experience.
        </p>
      </div>

      <!-- Carousel -->
      <div class="relative">
        <div id="testi-scroll" style="display:flex; gap:24px; overflow-x:auto; scroll-snap-type:x mandatory; -webkit-overflow-scrolling:touch; scrollbar-width:none; padding-bottom:4px; margin-top: 60px;">
          <% [
            { name: "Bro. Chukwuma", role: "State Coordinator", img: "https://randomuser.me/api/portraits/men/82.jpg", text: "TOM has been a transformational platform for teenagers across Nigeria. The impact we see in young lives is truly remarkable and life-changing." },
            { name: "Sis. Amaka", role: "Youth Worker", img: "https://randomuser.me/api/portraits/women/44.jpg", text: "Being part of TOM has given me the tools and training to effectively reach and mentor teenagers in my community. The growth has been phenomenal." },
            { name: "Bro. David", role: "Camp Volunteer", img: "https://randomuser.me/api/portraits/men/83.jpg", text: "The vacation camps are life-changing experiences. I've watched teenagers come in broken and leave with renewed hope, purpose, and faith in Christ." },
            { name: "Sis. Grace", role: "Parent", img: "https://randomuser.me/api/portraits/women/65.jpg", text: "My children have grown spiritually and in character since joining TOM programmes. I am deeply grateful for this ministry and its impact on families." },
            { name: "Bro. Emmanuel", role: "Training Facilitator", img: "https://randomuser.me/api/portraits/men/85.jpg", text: "TOM's emphasis on training workers is what sets it apart. You can't give what you don't have, and TOM invests heavily in equipping leaders." },
            { name: "Sis. Favour", role: "Teen Club Member", img: "https://randomuser.me/api/portraits/women/33.jpg", text: "I gave my life to Christ at a TOM Camp 2018. Now as an ambassador, I am helping to lead a Teenagers' Club in my Church. God is truly faithful!" }
          ].each do |t| %>
            <div style="flex:0 0 calc(33.333% - 16px); scroll-snap-align:start; min-width:300px;">
              <div class="rounded-2xl bg-white p-8 ring-gray-100 h-full flex flex-col" style="min-height:280px;">
                <!-- Stars -->
                <div class="flex gap-1 mb-4">
                  <% 5.times do %>
                    <svg style="width:16px;height:16px;" fill="#f59e0b" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  <% end %>
                </div>
                <!-- Quote text -->
                <p class="text-[15px] leading-7 text-gray-700 flex-grow">"<%= t[:text] %>"</p>
                <!-- Author -->
                <div class="flex items-center gap-4 mt-6 pt-5 border-t border-gray-100">
                  <img src="<%= t[:img] %>" alt="<%= t[:name] %>" style="width:48px;height:48px;border-radius:50%;object-fit:cover;" loading="lazy">
                  <div>
                    <p class="text-sm font-bold text-gray-900"><%= t[:name] %></p>
                    <p class="text-xs text-leaf-600 font-medium"><%= t[:role] %></p>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <!-- Nav arrows -->
        <div class="flex justify-center gap-4 mt-10 mb-bb">
          <button id="testi-prev" class="bg-white/10 hover:bg-white/20 border border-white/20 rounded-full flex items-center justify-center transition-all" style="width:48px;height:48px;">
            <svg style="width:20px;height:20px;" class="text-leaf" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/></svg>
          </button>
          <button id="testi-next" class="bg-leaf-600 hover:bg-leaf-500 rounded-full flex items-center justify-center transition-all shadow-lg" style="width:48px;height:48px;">
            <svg style="width:20px;height:20px;" class="text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
          </button>
        </div>
      </div>
    </div> 
  </div>
</div>

<style>
  .mb-bb { margin-bottom: 150px !important; }
  .mt-tt { margin-top: 50px !important; }
  .mt-tp { margin-top: -50px !important; }
  #testi-scroll::-webkit-scrollbar { display: none; }
  @media (max-width: 1023px) {
    #testi-scroll > div { flex: 0 0 calc(50% - 12px) !important; }
  }
  @media (max-width: 640px) {
    #testi-scroll > div { flex: 0 0 100% !important; min-width: 0 !important; }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    var s = document.getElementById("testi-scroll");
    if (!s) return;
    var auto;
    function scrollAmt() {
      var card = s.querySelector(":scope > div");
      return card ? card.offsetWidth + 24 : 340;
    }
    function go(dir) {
      s.scrollBy({ left: dir * scrollAmt(), behavior: "smooth" });
      clearInterval(auto);
      auto = setInterval(function(){ go(1); }, 5000);
    }
    document.getElementById("testi-prev").onclick = function(){ go(-1); };
    document.getElementById("testi-next").onclick = function(){ go(1); };
    auto = setInterval(function(){ go(1); }, 5000);
  });
</script>

