<section class="relative">
  <!-- TOP TWO-COLUMN ROW -->
  <div class="funfact-section">

    <!-- LEFT: dark overlay + text + top stats -->
    <div class="left-panel">
      <div class="left-content">
        <p class="label-funfact">Our FunFact</p>
        <h2 class="headline-funfact">A Glimpse of Our Journey<br>Across the World...</h2>
        <p class="subtext-funfact">
          We've come a long way – and we're just getting started!
          From humble beginnings to a growing international family,
          these highlights make our journey exciting and worth celebrating.
        </p>

        <div class="stats-grid-funfact">
          <!-- Teens Reached -->
          <div class="stat-item-funfact">
            <div class="stat-icon-funfact">
              <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="20" cy="20" r="8" stroke="currentColor" stroke-width="3" />
                <circle cx="44" cy="20" r="8" stroke="currentColor" stroke-width="3" />
                <path d="M4 52c0-8.837 7.163-16 16-16h8" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
                <path d="M60 52c0-8.837-7.163-16-16-16h-8" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
                <circle cx="32" cy="30" r="9" stroke="currentColor" stroke-width="3" />
                <path d="M14 58c0-9.941 8.059-18 18-18s18 8.059 18 18" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
              </svg>
            </div>
            <span class="stat-number-funfact">16 M+</span>
            <span class="stat-label-funfact">Teens Reached</span>
          </div>

          <!-- TOM Clubs -->
          <div class="stat-item-funfact" style="margin-bottom: 45px;">
            <div class="stat-icon-funfact">
              <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="32" cy="32" r="26" stroke="currentColor" stroke-width="3" />
                <ellipse cx="32" cy="32" rx="12" ry="26" stroke="currentColor" stroke-width="3" />
                <line x1="6" y1="32" x2="58" y2="32" stroke="currentColor" stroke-width="3" />
                <path d="M10 18c7 4 14 6 22 6s15-2 22-6" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
                <path d="M10 46c7-4 14-6 22-6s15 2 22 6" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
              </svg>
            </div>
            <span class="stat-number-funfact">60 +</span>
            <span class="stat-label-funfact">TOM Clubs</span>
          </div>
        </div>
      </div>
    </div>

    <!-- RIGHT: Africa-shaped image collage -->
    <div class="right-panel-funfact">
      <div class="africa-shape-wrapper">
        <div class="africa-clip-funfact">
          <%= image_tag "/funfact.png", class: "absolute inset-0 w-full h-full object-cover", alt: "Our Journey Across Africa" %>
        </div>
        <div class="quote-badge-funfact">"Give A Hand To Make The Better World"</div>
      </div>
    </div>

  </div>

