<% content_for :title, @page.title %>

<% case @page.template %>
<% when "contact" %>
  <div class="bg-white" style="padding-top: 120px;">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 pb-24">
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl"><%= @page.title %></h1>
        <div class="mt-4 text-lg leading-8 text-gray-600"><%= @page.body %></div>
      </div>

      <div class="mx-auto mt-16 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Headquarters -->
        <div class="rounded-2xl bg-gray-50 p-8 text-center">
          <div class="mx-auto flex items-center justify-center rounded-full bg-leaf-100" style="width:48px;height:48px;">
            <svg style="width:22px;height:22px;" class="text-leaf-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
          </div>
          <h3 class="mt-4 text-sm font-bold text-gray-900">Headquarters</h3>
          <p class="mt-2 text-sm text-gray-600">Kwali, Federal Capital Territory (FCT), Abuja, Nigeria</p>
        </div>

        <!-- Email -->
        <div class="rounded-2xl bg-gray-50 p-8 text-center">
          <div class="mx-auto flex items-center justify-center rounded-full bg-leaf-100" style="width:48px;height:48px;">
            <svg style="width:22px;height:22px;" class="text-leaf-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
          </div>
          <h3 class="mt-4 text-sm font-bold text-gray-900">Email</h3>
          <p class="mt-2 text-sm text-gray-600">info@tomint.org</p>
        </div>

        <!-- Social -->
        <div class="rounded-2xl bg-gray-50 p-8 text-center">
          <div class="mx-auto flex items-center justify-center rounded-full bg-leaf-100" style="width:48px;height:48px;">
            <svg style="width:22px;height:22px;" class="text-leaf-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" /></svg>
          </div>
          <h3 class="mt-4 text-sm font-bold text-gray-900">Social Media</h3>
          <p class="mt-2 text-sm text-gray-600">Follow us for updates and testimonies</p>
        </div>
      </div>
    </div>
  </div>

<% when "privacy" %>
  <div class="bg-white" style="padding-top: 120px;">
    <div class="mx-auto max-w-3xl px-6 lg:px-8 pb-24">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl"><%= @page.title %></h1>
      <p class="mt-4 text-sm text-gray-500">Last updated: <%= @page.updated_at.strftime("%B %d, %Y") %></p>

      <div class="mt-10 prose prose-lg prose-green max-w-none">
        <p>Your privacy is important to us. This policy explains how Teenagers' Outreach Ministries (TOM) Inc. collects, uses, and protects your personal information.</p>

        <h3>Information We Collect</h3>
        <p>We collect information you provide when registering for events, signing up for an account, or contacting us. This may include your name, email address, and phone number.</p>

        <h3>How We Use Your Information</h3>
        <p>We use your information solely to provide our services, communicate with you about events and programmes, and improve our ministry outreach.</p>

        <h3>Data Protection</h3>
        <p>We are committed to ensuring that your information is secure and will not share your personal data with third parties without your consent.</p>

        <h3>Cookies</h3>
        <p>Our website may use cookies to enhance your browsing experience. You can choose to accept or decline cookies through your browser settings.</p>

        <h3>Contact Us</h3>
        <p>If you have any questions about this privacy policy, please contact us at <a href="mailto:info@tomint.org">info@tomint.org</a>.</p>

        <% if @page.body.present? %>
          <hr>
          <%= @page.body %>
        <% end %>
      </div>
    </div>
  </div>

<% when "terms" %>
  <div class="bg-white" style="padding-top: 120px;">
    <div class="mx-auto max-w-3xl px-6 lg:px-8 pb-24">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl"><%= @page.title %></h1>
      <p class="mt-4 text-sm text-gray-500">Last updated: <%= @page.updated_at.strftime("%B %d, %Y") %></p>

      <div class="mt-10 prose prose-lg prose-green max-w-none">
        <p>By using the TOM International website and services, you agree to these terms and conditions.</p>

        <h3>Use of Service</h3>
        <p>This website is provided for informational purposes and to facilitate event registrations and ministry activities. Users are expected to provide accurate information when registering.</p>

        <h3>Account Responsibility</h3>
        <p>You are responsible for maintaining the confidentiality of your account credentials and all activities that occur under your account.</p>

        <h3>Event Registration</h3>
        <p>Registration for events is subject to availability. TOM reserves the right to cancel or modify events at any time, with notice provided to registered participants.</p>

        <h3>Intellectual Property</h3>
        <p>All content on this website, including text, images, and logos, is the property of Teenagers' Outreach Ministries (TOM) Inc. and is protected by applicable copyright laws.</p>

        <h3>Contact</h3>
        <p>If you have any questions about these terms, please contact us at <a href="mailto:info@tomint.org">info@tomint.org</a>.</p>

        <% if @page.body.present? %>
          <hr>
          <%= @page.body %>
        <% end %>
      </div>
    </div>
  </div>

<% else %>
  <div class="bg-white" style="padding-top: 120px;">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 pb-24">
      <div class="mx-auto max-w-3xl">
        <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl mb-8"><%= @page.title %></h1>
        <div class="prose prose-lg prose-green mx-auto">
          <%= @page.body %>
        </div>
      </div>
    </div>
  </div>
<% end %>
