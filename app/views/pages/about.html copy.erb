          <dd class="order-first text-2xl font-bold tracking-tight text-leaf-600"><%= Time.current.year - 1992 %>+</dd>
          <dt class="text-xs font-medium leading-6 text-gray-500 uppercase tracking-wide">Years</dt>
        </div>
        <div class="flex flex-col gap-y-1">
          <dd class="order-first text-2xl font-bold tracking-tight text-leaf-600">24+</dd>
          <dt class="text-xs font-medium leading-6 text-gray-500 uppercase tracking-wide">States</dt>
        </div>
        <div class="flex flex-col gap-y-1">
          <dd class="order-first text-2xl font-bold tracking-tight text-leaf-600">50k+</dd>
          <dt class="text-xs font-medium leading-6 text-gray-500 uppercase tracking-wide">Lives</dt>
        </div>
        <div class="flex flex-col gap-y-1">
          <dd class="order-first text-2xl font-bold tracking-tight text-leaf-600">500+</dd>
          <dt class="text-xs font-medium leading-6 text-gray-500 uppercase tracking-wide">Volunteers</dt>
        </div>
      </dl>
  </div>

