<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "TOM Int. - Raise Leaders, Impact Generations" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="<%= image_path 'logo.png' %>" type="image/png">
    <link rel="apple-touch-icon" href="<%= image_path 'logo.png' %>">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@600&family=Playfair+Display:ital,wght@0,700;1,600&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "mobile_forms", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "funfacts", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "volunteer", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-stone-50 font-sans text-gray-900 antialiased selection:bg-leaf-100 selection:text-leaf-900 min-h-screen flex flex-col">
    <%= render "shared/public_header" %>

    <main class="isolate flex-auto">
      <% if notice %>
        <div class="flash-alert fixed top-20 right-5 z-50 p-4 text-leaf-700 bg-leaf-50 rounded-lg shadow-lg border border-leaf-100" role="alert" style="transition: opacity 0.5s ease;">
          <%= notice %>
        </div>
      <% end %>
      <% if alert %>
        <div class="flash-alert fixed top-20 right-5 z-50 p-4 text-red-700 bg-red-50 rounded-lg shadow-lg border border-red-100" role="alert" style="transition: opacity 0.5s ease;">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <%= render "shared/footer" %>

    <script>
      (function() {
        function fade() {
          var alerts = document.querySelectorAll('.flash-alert');
          for (var i = 0; i < alerts.length; i++) {
            (function(el) {
              if (el.dataset.fadeBound) return;
              el.dataset.fadeBound = '1';
              setTimeout(function() { el.style.opacity = '0'; }, 4000);
              setTimeout(function() { el.remove(); }, 4500);
            })(alerts[i]);
          }
        }
        fade();
        document.addEventListener('turbo:load', fade);
        document.addEventListener('turbo:render', fade);
      })();
    </script>
  </body>
</html>
